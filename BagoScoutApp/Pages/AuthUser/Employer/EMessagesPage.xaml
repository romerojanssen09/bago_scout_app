<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             xmlns:components="clr-namespace:BagoScoutApp.Pages.AuthUser.Employer.Components"
             x:Class="BagoScoutApp.Pages.AuthUser.Employer.EMessagesPage"
             Title="Messages"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8FAFC">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Main Content Grid -->
        <Grid Grid.Row="0">
            <!-- 1. Conversations List View -->
            <Grid x:Name="ConversationsGrid" RowDefinitions="Auto, *" Padding="20,16,20,20" RowSpacing="18" IsVisible="True">
                <Label Grid.Row="0" 
                       Text="Inbox" 
                       FontFamily="Inter"
                       FontAttributes="Bold"
                       FontSize="28"
                       TextColor="#0F172A"
                       Margin="0,8,0,0"/>

                <Grid Grid.Row="1">
                    <!-- Loading Spinner - Only visible when loading -->
                    <VerticalStackLayout x:Name="ConversationsLoadingContainer" 
                                         IsVisible="False" 
                                         HorizontalOptions="Center" 
                                         VerticalOptions="Center"
                                         Spacing="14">
                        <ActivityIndicator x:Name="ConversationsLoadingIndicator" 
                                           IsRunning="False"
                                           Color="#6C63FF" 
                                           HeightRequest="50"
                                           WidthRequest="50"/>
                        <Label Text="Loading conversations..." 
                               FontFamily="Inter"
                               FontAttributes="Bold"
                               FontSize="15" 
                               TextColor="#64748B"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Conversations List -->
                    <CollectionView x:Name="ConversationsCollectionView" 
                                    SelectionMode="None"
                                    IsVisible="True">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="40,50" Spacing="14" HorizontalOptions="Center" VerticalOptions="Center">
                            <Border WidthRequest="72" 
                                    HeightRequest="72" 
                                    StrokeThickness="0" 
                                    BackgroundColor="#F1F5F9" 
                                    StrokeShape="RoundRectangle 20"
                                    HorizontalOptions="Center">
                                <Label Text="&#xf4ad;" 
                                       FontFamily="FASolid" 
                                       FontSize="32" 
                                       TextColor="#94A3B8" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="No conversations yet" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="18" 
                                   TextColor="#0F172A" 
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Candidate messages will appear here" 
                                   FontFamily="Inter"
                                   FontSize="14" 
                                   TextColor="#64748B" 
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0"
                                    BackgroundColor="White"
                                    Margin="0,0,0,12"
                                    Padding="16">
                                <Border.Shadow>
                                    <Shadow Brush="#64748B" Offset="0,4" Radius="16" Opacity="0.06"/>
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnConversationTapped" CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="56, *, Auto" ColumnSpacing="14">
                                     <!-- Avatar -->
                                     <Border Grid.Column="0" 
                                             WidthRequest="56" 
                                             HeightRequest="56" 
                                             StrokeShape="RoundRectangle 16" 
                                             StrokeThickness="2"
                                             Stroke="#F1F5F9"
                                             BackgroundColor="#F8FAFC" 
                                             VerticalOptions="Center">
                                         <Grid>
                                             <Label Text="&#xf007;" 
                                                    FontFamily="FASolid" 
                                                    FontSize="24" 
                                                    TextColor="#CBD5E1" 
                                                    HorizontalOptions="Center" 
                                                    VerticalOptions="Center"/>
                                             <Border StrokeShape="RoundRectangle 16" 
                                                     StrokeThickness="0"
                                                     BackgroundColor="Transparent">
                                                 <Image Source="{Binding selfiePhotoUrl}" 
                                                        Aspect="AspectFill"/>
                                             </Border>
                                         </Grid>
                                     </Border>

                                     <!-- Content -->
                                     <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                         <Label Text="{Binding fullName}" 
                                                FontFamily="Inter"
                                                FontAttributes="Bold"
                                                FontSize="16" 
                                                TextColor="#0F172A"/>
                                         <Label Text="{Binding lastMessage}" 
                                                FontFamily="Inter"
                                                FontSize="13" 
                                                TextColor="#64748B" 
                                                MaxLines="1" 
                                                LineBreakMode="TailTruncation"/>
                                     </VerticalStackLayout>

                                     <!-- Meta details -->
                                     <VerticalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">
                                         <Label Text="{Binding lastMessageTime, StringFormat='{0:h:mm tt}'}" 
                                                FontFamily="Inter"
                                                FontSize="11" 
                                                TextColor="#94A3B8"/>
                                         <!-- Unread Badge -->
                                         <Border Padding="8,3" BackgroundColor="{StaticResource Primary}" StrokeThickness="0" StrokeShape="RoundRectangle 12" HorizontalOptions="End">
                                             <Border.Triggers>
                                                 <DataTrigger TargetType="Border" Binding="{Binding unreadCount}" Value="0">
                                                     <Setter Property="IsVisible" Value="False"/>
                                                 </DataTrigger>
                                             </Border.Triggers>
                                             <Label Text="{Binding unreadCount}" 
                                                    FontFamily="Inter"
                                                    FontAttributes="Bold"
                                                    FontSize="10" 
                                                    TextColor="White"/>
                                         </Border>
                                     </VerticalStackLayout>
                                 </Grid>
                             </Border>
                         </DataTemplate>
                     </CollectionView.ItemTemplate>
                 </CollectionView>
             </Grid>
         </Grid>

            <!-- 2. Chat Thread View -->
            <Grid x:Name="ChatThreadGrid" RowDefinitions="Auto, *, Auto" IsVisible="False">
                <!-- Chat Header -->
                <Border Grid.Row="0" StrokeShape="RoundRectangle 0" BackgroundColor="White" Padding="16,10" Stroke="{StaticResource Gray200}" StrokeThickness="1">
                    <Grid ColumnDefinitions="Auto, Auto, *, Auto" ColumnSpacing="12" VerticalOptions="Center">
                        <!-- Back button with FontAwesome left arrow -->
                        <Grid Grid.Column="0" WidthRequest="36" HeightRequest="36" VerticalOptions="Center" HorizontalOptions="Center">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackToConversationsClicked"/>
                            </Grid.GestureRecognizers>
                            <Label Text="&#xf060;" FontFamily="FASolid" FontSize="18" TextColor="{StaticResource PrimaryDark}" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Vertical Separator -->
                        <Label Grid.Column="1" Text="|" FontSize="20" TextColor="{StaticResource Gray200}" VerticalOptions="Center" Margin="0,0,0,2"/>

                        <!-- Partner Info -->
                        <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                            <Label x:Name="ChatPartnerLabel" 
                                   Text="Candidate Name" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="17" 
                                   TextColor="#0F172A"/>
                            <Label Text="Seeker" 
                                   FontFamily="Inter"
                                   FontSize="13" 
                                   TextColor="#64748B"/>
                        </VerticalStackLayout>

                        <!-- Profile Pic (Clickable) -->
                        <Border Grid.Column="3" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="{StaticResource Secondary}" VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnProfilePicClicked"/>
                            </Border.GestureRecognizers>
                            <Grid>
                                <Label Text="&#xf007;" FontFamily="FASolid" FontSize="18" TextColor="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Image x:Name="ChatPartnerImage" Aspect="AspectFill" BackgroundColor="Transparent"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Messages Thread -->
                <CollectionView Grid.Row="1" x:Name="MessagesCollectionView" Margin="16,0" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- Message Card -->
                            <Grid Margin="0,6" ColumnDefinitions="*, Auto, *">
                                <Border HorizontalOptions="{Binding alignment}"
                                        StrokeThickness="0"
                                        Padding="16,12"
                                        Grid.ColumnSpan="3"
                                        MaximumWidthRequest="290"
                                        BackgroundColor="{Binding bubbleColor}"
                                        StrokeShape="{Binding strokeShape}">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding messageText}" 
                                               FontFamily="Inter"
                                               FontSize="14" 
                                               TextColor="{Binding textColor}"/>
                                        <Label Text="{Binding sentAt, StringFormat='{0:h:mm tt}'}" 
                                               FontFamily="Inter"
                                               FontSize="10" 
                                               TextColor="{Binding timeColor}" 
                                               HorizontalOptions="End"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Input Row -->
                <Border Grid.Row="2" StrokeThickness="0" BackgroundColor="White" Padding="16,14">
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 14" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="14,0" HeightRequest="48">
                            <Entry x:Name="MessageEntry" 
                                   Placeholder="Type a message..." 
                                   FontFamily="Inter"
                                   FontSize="14" 
                                   TextColor="#0F172A" 
                                   VerticalOptions="Center"/>
                        </Border>
                        <Button Grid.Column="1" 
                                Text="Send" 
                                FontFamily="Inter"
                                Clicked="OnSendMessageClicked" 
                                BackgroundColor="{StaticResource Primary}" 
                                TextColor="White" 
                                CornerRadius="14" 
                                WidthRequest="80" 
                                HeightRequest="48" 
                                FontAttributes="Bold" 
                                FontSize="14"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!-- Profile Details Overlay -->
        <Grid x:Name="ProfileDetailsOverlay" BackgroundColor="#80000000" IsVisible="False" Grid.Row="0">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseProfileOverlayClicked"/>
            </Grid.GestureRecognizers>
            
            <Border VerticalOptions="End"
                    HeightRequest="560"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    Padding="24,20">
                <Border.Shadow>
                    <Shadow Brush="#64748B" Offset="0,-6" Radius="20" Opacity="0.15"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer /> <!-- Intercept taps -->
                </Border.GestureRecognizers>
                
                <Grid RowDefinitions="Auto, *, Auto" RowSpacing="18">
                    <!-- Title Row -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                        <Label x:Name="OverlayTitleLabel" 
                               Text="Candidate Profile" 
                               FontFamily="Inter"
                               FontAttributes="Bold"
                               FontSize="20" 
                               TextColor="#0F172A" 
                               VerticalOptions="Center"/>
                        <Button Grid.Column="1" 
                                Text="&#xf00d;" 
                                FontFamily="FASolid" 
                                Clicked="OnCloseProfileOverlayClicked" 
                                BackgroundColor="Transparent" 
                                TextColor="#94A3B8" 
                                FontSize="18" 
                                WidthRequest="44" 
                                HeightRequest="44"
                                Padding="0"/>
                    </Grid>

                    <!-- Scrollable Content -->
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Spacing="18">
                            <!-- Selfie and Name -->
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,10">
                                <Border WidthRequest="90" 
                                        HeightRequest="90" 
                                        StrokeShape="RoundRectangle 24" 
                                        StrokeThickness="3"
                                        Stroke="{StaticResource Primary}"
                                        BackgroundColor="{StaticResource Secondary}" 
                                        HorizontalOptions="Center">
                                    <Grid>
                                        <Label Text="&#xf007;" 
                                               FontFamily="FASolid" 
                                               FontSize="40" 
                                               TextColor="{StaticResource Primary}" 
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center"/>
                                        <Image x:Name="OverlaySelfieImage" 
                                               Aspect="AspectFill" 
                                               BackgroundColor="Transparent"/>
                                    </Grid>
                                </Border>
                                <Label x:Name="OverlayNameLabel" 
                                       Text="-" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="20" 
                                       TextColor="#0F172A" 
                                       HorizontalOptions="Center"/>
                                <Label x:Name="OverlayJobTitleLabel" 
                                       Text="-" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="14" 
                                       TextColor="{StaticResource Primary}" 
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Contact Info Block -->
                            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="#F8FAFC" Padding="16">
                                <VerticalStackLayout Spacing="10">
                                    <Label x:Name="OverlayEmailLabel" 
                                           Text="✉ -" 
                                           FontFamily="Inter"
                                           FontSize="13" 
                                           TextColor="#0F172A"/>
                                    <Label x:Name="OverlayPhoneLabel" 
                                           Text="☏ -" 
                                           FontFamily="Inter"
                                           FontSize="13" 
                                           TextColor="#0F172A"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Skills Section -->
                            <Label Text="Skills" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="16" 
                                   TextColor="#0F172A"/>
                            <FlexLayout x:Name="OverlaySkillsLayout" Wrap="Wrap" Direction="Row" AlignItems="Center" JustifyContent="Start"/>

                            <!-- Experience Section -->
                            <Label Text="Work Experience" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="16" 
                                   TextColor="#0F172A" 
                                   Margin="0,10,0,0"/>
                            <VerticalStackLayout x:Name="OverlayExperienceLayout" Spacing="12"/>

                            <!-- Education Section -->
                            <Label Text="Education" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="16" 
                                   TextColor="#0F172A" 
                                   Margin="0,10,0,0"/>
                            <VerticalStackLayout x:Name="OverlayEducationLayout" Spacing="12"/>
                        </VerticalStackLayout>
                    </ScrollView>
                    
                    <Button Grid.Row="2" 
                            Text="Close Profile" 
                            FontFamily="Inter"
                            Clicked="OnCloseProfileOverlayClicked" 
                            BackgroundColor="#F1F5F9" 
                            TextColor="#0F172A" 
                            HeightRequest="50" 
                            CornerRadius="12" 
                            FontSize="15"
                            FontAttributes="Bold"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Navigation -->
        <components:BottomNav Grid.Row="1" x:Name="BottomNavigation" ActivePage="messages"/>
    </Grid>
</base:BasePage>

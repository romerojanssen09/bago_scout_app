<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             xmlns:components="clr-namespace:BagoScoutApp.Pages.AuthUser.Employer.Components"
             x:Class="BagoScoutApp.Pages.AuthUser.Employer.ECandidatesPage"
             Title="Candidates"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8FAFC">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Main Content Area -->
        <Grid Grid.Row="0" RowDefinitions="Auto, Auto, *">
            <!-- Header -->
            <VerticalStackLayout Grid.Row="0" Padding="20,20,20,10" Spacing="8">
                <Label Text="Candidate Applications" 
                       FontFamily="Inter"
                       FontAttributes="Bold"
                       FontSize="28"
                       TextColor="#0F172A"
                       Margin="0,8,0,0"/>
                <Label Text="Review and manage applicants for your job postings" 
                       FontFamily="Inter"
                       FontSize="15"
                       TextColor="#64748B"/>
            </VerticalStackLayout>

            <!-- Filter Button Card -->
            <Border Grid.Row="1" Margin="20,0,20,14" StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="16,12">
                <Border.Shadow>
                    <Shadow Brush="#64748B" Offset="0,2" Radius="12" Opacity="0.06"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFilterButtonClicked"/>
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Label Grid.Column="0" 
                           Text="Filter by Job:" 
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#0F172A" 
                           VerticalOptions="Center" 
                           Margin="0,0,12,0"/>
                    <Label Grid.Column="1" 
                           x:Name="FilterLabel"
                           Text="All Jobs"
                           FontFamily="Inter"
                           FontSize="15" 
                           TextColor="#6C63FF" 
                           VerticalOptions="Center"/>
                    <Label Grid.Column="2" 
                           Text="&#xf107;" 
                           FontFamily="FASolid" 
                           FontSize="14" 
                           TextColor="#94A3B8" 
                           VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- List of Candidates -->
            <Grid Grid.Row="2" Padding="20,0">
                <!-- Loading Spinner - Only visible when loading -->
                <VerticalStackLayout x:Name="LoadingContainer" 
                                     IsVisible="False" 
                                     HorizontalOptions="Center" 
                                     VerticalOptions="Center"
                                     Spacing="14">
                    <ActivityIndicator x:Name="LoadingIndicator" 
                                       IsRunning="False"
                                       Color="#6C63FF" 
                                       HeightRequest="50"
                                       WidthRequest="50"/>
                    <Label Text="Loading candidates..." 
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="15" 
                           TextColor="#64748B"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Candidates List -->
                <CollectionView x:Name="CandidatesCollectionView" 
                                SelectionMode="None"
                                IsVisible="True">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout x:Name="EmptyStateContainer"
                                             Padding="40,50" 
                                             Spacing="14" 
                                             HorizontalOptions="Center" 
                                             VerticalOptions="Center">
                            <Border WidthRequest="72" 
                                    HeightRequest="72" 
                                    StrokeThickness="0" 
                                    BackgroundColor="#F1F5F9" 
                                    StrokeShape="RoundRectangle 20"
                                    HorizontalOptions="Center">
                                <Label Text="&#xf0c0;" 
                                       FontFamily="FASolid" 
                                       FontSize="32" 
                                       TextColor="#94A3B8" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="No candidates found" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="18" 
                                   TextColor="#0F172A" 
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Try choosing another job filter" 
                                   FontFamily="Inter"
                                   FontSize="14" 
                                   TextColor="#64748B" 
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="White" Margin="0,0,0,14" Padding="18">
                                <Border.Shadow>
                                    <Shadow Brush="#64748B" Offset="0,4" Radius="16" Opacity="0.06"/>
                                </Border.Shadow>
                                <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="10">
                                    <!-- Header: Name, Date, Status -->
                                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">
                                        <!-- Photo/Avatar -->
                                        <Border Grid.Column="0" 
                                                WidthRequest="56" 
                                                HeightRequest="56" 
                                                StrokeShape="RoundRectangle 16" 
                                                StrokeThickness="2"
                                                Stroke="#F1F5F9"
                                                BackgroundColor="#F8FAFC">
                                            <Grid>
                                                <Label Text="&#xf007;" 
                                                       FontFamily="FASolid" 
                                                       FontSize="24" 
                                                       TextColor="#CBD5E1" 
                                                       HorizontalOptions="Center" 
                                                       VerticalOptions="Center"/>
                                                <Border StrokeShape="RoundRectangle 16" 
                                                        StrokeThickness="0"
                                                        BackgroundColor="Transparent">
                                                    <Image Source="{Binding seekerPhoto}" 
                                                           Aspect="AspectFill"/>
                                                </Border>
                                            </Grid>
                                        </Border>
 
                                        <!-- Title details -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                            <Label Text="{Binding seekerName}" 
                                                   FontFamily="Inter"
                                                   FontAttributes="Bold"
                                                   FontSize="16"
                                                   TextColor="#0F172A"/>
                                            <Label Text="{Binding jobTitle, StringFormat='Applied for: {0}'}" 
                                                   FontFamily="Inter"
                                                   FontAttributes="Bold"
                                                   FontSize="13" 
                                                   TextColor="{StaticResource Primary}"
                                                   MaxLines="1" 
                                                   LineBreakMode="TailTruncation"/>
                                        </VerticalStackLayout>
 
                                        <!-- Status Badge -->
                                        <Border Grid.Column="2" Padding="12,6" StrokeThickness="0" StrokeShape="RoundRectangle 12" VerticalOptions="Start">
                                            <Border.Triggers>
                                                <!-- Pending Status -->
                                                <DataTrigger TargetType="Border" Binding="{Binding status}" Value="Pending">
                                                    <Setter Property="BackgroundColor" Value="#FEF3C7"/>
                                                </DataTrigger>
                                                <!-- Reviewed Status -->
                                                <DataTrigger TargetType="Border" Binding="{Binding status}" Value="Reviewed">
                                                    <Setter Property="BackgroundColor" Value="#DBEAFE"/>
                                                </DataTrigger>
                                                <!-- Accepted Status -->
                                                <DataTrigger TargetType="Border" Binding="{Binding status}" Value="Accepted">
                                                    <Setter Property="BackgroundColor" Value="#D1FAE5"/>
                                                </DataTrigger>
                                                <!-- Rejected Status -->
                                                <DataTrigger TargetType="Border" Binding="{Binding status}" Value="Rejected">
                                                    <Setter Property="BackgroundColor" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            
                                            <Label Text="{Binding status}" 
                                                   FontFamily="Inter"
                                                   FontAttributes="Bold"
                                                   FontSize="12">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding status}" Value="Pending">
                                                        <Setter Property="TextColor" Value="#92400E"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding status}" Value="Reviewed">
                                                        <Setter Property="TextColor" Value="#1E40AF"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding status}" Value="Accepted">
                                                        <Setter Property="TextColor" Value="#065F46"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding status}" Value="Rejected">
                                                        <Setter Property="TextColor" Value="#991B1B"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>
                                    </Grid>
 
                                    <!-- Candidate Info Details -->
                                    <VerticalStackLayout Grid.Row="1" Spacing="6">
                                        <Label Text="{Binding seekerEmail, StringFormat='✉ {0}'}" 
                                               FontFamily="Inter"
                                               FontSize="13" 
                                               TextColor="#64748B"/>
                                        <Label Text="{Binding seekerPhone, StringFormat='☏ {0}'}" 
                                               FontFamily="Inter"
                                               FontSize="13" 
                                               TextColor="#64748B"/>
                                        <Label Text="{Binding appliedAt, StringFormat='📅 Applied on {0:MMM dd, yyyy}'}" 
                                               FontFamily="Inter"
                                               FontSize="12" 
                                               TextColor="#94A3B8"/>
                                    </VerticalStackLayout>
 
                                    <!-- Action Buttons -->
                                    <Grid Grid.Row="2" ColumnDefinitions="*, *, *" ColumnSpacing="10" Margin="0,4,0,0">
                                        <!-- Accept Button -->
                                        <Button Grid.Column="0"
                                                x:Name="AcceptBtn"
                                                Text="Accept"
                                                Clicked="OnAcceptCandidateClicked"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#D1FAE5"
                                                TextColor="#065F46"
                                                FontFamily="Inter"
                                                FontAttributes="Bold"
                                                FontSize="13"
                                                CornerRadius="10"
                                                HeightRequest="40">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding status}" Value="Accepted">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button" Binding="{Binding status}" Value="Rejected">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
 
                                        <!-- Reject Button -->
                                        <Button Grid.Column="1"
                                                x:Name="RejectBtn"
                                                Text="Reject"
                                                Clicked="OnRejectCandidateClicked"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#FEE2E2"
                                                TextColor="#991B1B"
                                                FontFamily="Inter"
                                                FontAttributes="Bold"
                                                FontSize="13"
                                                CornerRadius="10"
                                                HeightRequest="40">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding status}" Value="Accepted">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button" Binding="{Binding status}" Value="Rejected">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
 
                                        <!-- More Actions Button -->
                                        <Button Grid.Column="2"
                                                Text="&#xf142;"
                                                FontFamily="FASolid"
                                                Clicked="OnMoreActionsClicked"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource Secondary}"
                                                TextColor="{StaticResource PrimaryDark}"
                                                BorderColor="{StaticResource Gray200}"
                                                BorderWidth="1"
                                                FontSize="14"
                                                CornerRadius="10"
                                                HeightRequest="40">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding status}" Value="Accepted">
                                                    <Setter Property="Grid.ColumnSpan" Value="3"/>
                                                    <Setter Property="Grid.Column" Value="0"/>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDark}"/>
                                                    <Setter Property="TextColor" Value="White"/>
                                                    <Setter Property="Text" Value="Actions"/>
                                                    <Setter Property="FontFamily" Value="Inter"/>
                                                    <Setter Property="FontAttributes" Value="Bold"/>
                                                    <Setter Property="FontSize" Value="13"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button" Binding="{Binding status}" Value="Rejected">
                                                    <Setter Property="Grid.ColumnSpan" Value="3"/>
                                                    <Setter Property="Grid.Column" Value="0"/>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDark}"/>
                                                    <Setter Property="TextColor" Value="White"/>
                                                    <Setter Property="Text" Value="Actions"/>
                                                    <Setter Property="FontFamily" Value="Inter"/>
                                                    <Setter Property="FontAttributes" Value="Bold"/>
                                                    <Setter Property="FontSize" Value="13"/>
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>

        <!-- Bottom Navigation -->
        <components:BottomNav Grid.Row="1" x:Name="BottomNavigation" ActivePage="candidates"/>

        <!-- Seeker Profile Details Modal Overlay -->
        <Grid x:Name="ProfileDetailsOverlay" BackgroundColor="#80000000" IsVisible="False" Grid.RowSpan="2">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseProfileOverlayClicked"/>
            </Grid.GestureRecognizers>
            <Border VerticalOptions="End"
                    HeightRequest="560"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    Padding="24,20">
                <Border.Shadow>
                    <Shadow Brush="#64748B" Offset="0,-6" Radius="20" Opacity="0.15"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer /> <!-- Intercept taps -->
                </Border.GestureRecognizers>
                
                <Grid RowDefinitions="Auto, *, Auto" RowSpacing="18">
                    <!-- Title Row -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                        <Label x:Name="OverlayTitleLabel" 
                               Text="Candidate Profile" 
                               FontFamily="Inter"
                               FontAttributes="Bold"
                               FontSize="20" 
                               TextColor="#0F172A" 
                               VerticalOptions="Center"/>
                        <Button Grid.Column="1" 
                                Text="&#xf00d;" 
                                FontFamily="FASolid" 
                                Clicked="OnCloseProfileOverlayClicked" 
                                BackgroundColor="Transparent" 
                                TextColor="#94A3B8" 
                                FontSize="18" 
                                WidthRequest="44" 
                                HeightRequest="44"
                                Padding="0"/>
                    </Grid>

                    <!-- Scrollable Content -->
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Spacing="18">
                            <!-- Selfie and Name -->
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,10">
                                <Border WidthRequest="90" 
                                        HeightRequest="90" 
                                        StrokeShape="RoundRectangle 24" 
                                        StrokeThickness="3"
                                        Stroke="{StaticResource Primary}"
                                        BackgroundColor="{StaticResource Secondary}" 
                                        HorizontalOptions="Center">
                                    <Grid>
                                        <Label Text="&#xf007;" 
                                               FontFamily="FASolid" 
                                               FontSize="40" 
                                               TextColor="{StaticResource Primary}" 
                                               HorizontalOptions="Center" 
                                               VerticalOptions="Center"/>
                                        <Image x:Name="OverlaySelfieImage" 
                                               Aspect="AspectFill" 
                                               BackgroundColor="Transparent"/>
                                    </Grid>
                                </Border>
                                <Label x:Name="OverlayNameLabel" 
                                       Text="-" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="20" 
                                       TextColor="#0F172A" 
                                       HorizontalOptions="Center"/>
                                <Label x:Name="OverlayJobTitleLabel" 
                                       Text="-" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="14" 
                                       TextColor="{StaticResource Primary}" 
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Contact Info Block -->
                            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="#F8FAFC" Padding="16">
                                <VerticalStackLayout Spacing="10">
                                    <Label x:Name="OverlayEmailLabel" 
                                           Text="✉ -" 
                                           FontFamily="Inter"
                                           FontSize="13" 
                                           TextColor="#0F172A"/>
                                    <Label x:Name="OverlayPhoneLabel" 
                                           Text="☏ -" 
                                           FontFamily="Inter"
                                           FontSize="13" 
                                           TextColor="#0F172A"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Skills Section -->
                            <Label Text="Skills" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="16" 
                                   TextColor="#0F172A"/>
                            <FlexLayout x:Name="OverlaySkillsLayout" Wrap="Wrap" Direction="Row" AlignItems="Center" JustifyContent="Start"/>

                            <!-- Experience Section -->
                            <Label Text="Work Experience" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="16" 
                                   TextColor="#0F172A" 
                                   Margin="0,10,0,0"/>
                            <VerticalStackLayout x:Name="OverlayExperienceLayout" Spacing="12"/>

                            <!-- Education Section -->
                            <Label Text="Education" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="16" 
                                   TextColor="#0F172A" 
                                   Margin="0,10,0,0"/>
                            <VerticalStackLayout x:Name="OverlayEducationLayout" Spacing="12"/>
                        </VerticalStackLayout>
                    </ScrollView>
                    
                    <Button Grid.Row="2" 
                            Text="Close Profile" 
                            FontFamily="Inter"
                            Clicked="OnCloseProfileOverlayClicked" 
                            BackgroundColor="#F1F5F9" 
                            TextColor="#0F172A" 
                            HeightRequest="50" 
                            CornerRadius="12" 
                            FontSize="15"
                            FontAttributes="Bold"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Email Compose/History Modal Overlay -->
        <Grid x:Name="EmailOverlay" BackgroundColor="#80000000" IsVisible="False" Grid.RowSpan="2">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseEmailOverlayClicked"/>
            </Grid.GestureRecognizers>
            <Border VerticalOptions="End"
                    HeightRequest="520"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    Padding="24,20">
                <Border.Shadow>
                    <Shadow Brush="#64748B" Offset="0,-6" Radius="20" Opacity="0.15"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer /> <!-- Intercept taps -->
                </Border.GestureRecognizers>
                
                <Grid RowDefinitions="Auto, *, Auto" RowSpacing="18">
                    <!-- Title Row -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                        <Label x:Name="EmailOverlayTitle" 
                               Text="Email Candidate" 
                               FontFamily="Inter"
                               FontAttributes="Bold"
                               FontSize="20" 
                               TextColor="#0F172A" 
                               VerticalOptions="Center"/>
                        <Button Grid.Column="1" 
                                Text="&#xf00d;" 
                                FontFamily="FASolid" 
                                Clicked="OnCloseEmailOverlayClicked" 
                                BackgroundColor="Transparent" 
                                TextColor="#94A3B8" 
                                FontSize="18" 
                                WidthRequest="44" 
                                HeightRequest="44"
                                Padding="0"/>
                    </Grid>
 
                    <!-- Content -->
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Spacing="18">
                            <!-- View Compose Form -->
                            <VerticalStackLayout x:Name="EmailComposeLayout" Spacing="14">
                                <Label Text="Subject" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="13" 
                                       TextColor="#0F172A"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="White" Padding="14,0" HeightRequest="48">
                                    <Entry x:Name="EmailSubjectEntry" 
                                           Placeholder="e.g. Interview invitation" 
                                           FontFamily="Inter"
                                           FontSize="14" 
                                           TextColor="#0F172A" 
                                           VerticalOptions="Center"/>
                                </Border>
 
                                <Label Text="Message Body" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="13" 
                                       TextColor="#0F172A"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="White" Padding="14,8">
                                    <Editor x:Name="EmailBodyEditor" 
                                            Placeholder="Write your message here..." 
                                            HeightRequest="130" 
                                            FontFamily="Inter"
                                            FontSize="14" 
                                            TextColor="#0F172A"/>
                                </Border>
                            </VerticalStackLayout>
                            
                            <!-- Email History Header -->
                            <Label x:Name="EmailHistoryHeader" 
                                   Text="Sent Emails History" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="16" 
                                   TextColor="#0F172A" 
                                   Margin="0,10,0,0" 
                                   IsVisible="False"/>
                            <VerticalStackLayout x:Name="EmailHistoryLayout" Spacing="10" IsVisible="False"/>
                        </VerticalStackLayout>
                    </ScrollView>
 
                    <!-- Buttons -->
                    <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,12,0,10">
                        <Button Grid.Column="0" 
                                Text="Close" 
                                FontFamily="Inter"
                                Clicked="OnCloseEmailOverlayClicked" 
                                BackgroundColor="#F1F5F9" 
                                TextColor="#0F172A" 
                                HeightRequest="50" 
                                CornerRadius="12" 
                                FontSize="15"
                                FontAttributes="Bold"/>
                        <Button Grid.Column="1" 
                                x:Name="SendEmailSubmitBtn" 
                                Text="Send Email" 
                                FontFamily="Inter"
                                Clicked="OnSendEmailSubmitClicked" 
                                BackgroundColor="{StaticResource Primary}" 
                                TextColor="White" 
                                HeightRequest="50" 
                                CornerRadius="12" 
                                FontSize="15"
                                FontAttributes="Bold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</base:BasePage>

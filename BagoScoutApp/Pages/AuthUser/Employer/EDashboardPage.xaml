<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             xmlns:components="clr-namespace:BagoScoutApp.Pages.AuthUser.Employer.Components"
             x:Class="BagoScoutApp.Pages.AuthUser.Employer.EDashboardPage"
             Title="Employer Dashboard"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8FAFC">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Main Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16,20,24" Spacing="24">
                <!-- Welcome Section -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,8,0,4">
                    <VerticalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                        <Label x:Name="WelcomeLabel"
                               Text="Welcome back! 👋" 
                               FontFamily="Inter"
                               FontAttributes="Bold"
                               FontSize="28"
                               TextColor="#0F172A"
                               LineHeight="1.2"/>
                        <Label Text="Manage your job postings and review candidates" 
                               FontFamily="Inter"
                               FontSize="15"
                               TextColor="#64748B"
                               LineHeight="1.4"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            WidthRequest="52"
                            HeightRequest="52"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}"
                            VerticalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="#6C63FF" Offset="0,4" Radius="12" Opacity="0.25"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBuildingIconTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="&#xf1ad;" 
                               FontFamily="FASolid"
                               FontSize="22" 
                               TextColor="White"
                               HorizontalOptions="Center" 
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Stats Grid (2x2) -->
                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" RowSpacing="14" ColumnSpacing="14">
                    <!-- Active Jobs -->
                    <Border Grid.Row="0" Grid.Column="0" 
                            BackgroundColor="White" 
                            StrokeThickness="0" 
                            Padding="16,18" 
                            StrokeShape="RoundRectangle 20">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="12" Opacity="0.08"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Active Jobs" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="13" 
                                       TextColor="#64748B" 
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" 
                                        WidthRequest="36" 
                                        HeightRequest="36" 
                                        StrokeShape="RoundRectangle 11" 
                                        StrokeThickness="0" 
                                        BackgroundColor="#EEF2FF">
                                    <Label Text="&#xf0b1;" 
                                           FontFamily="FASolid" 
                                           FontSize="16" 
                                           TextColor="#6366F1" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <Label x:Name="ActiveJobsCountLabel" 
                                   Text="0" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="32" 
                                   TextColor="#0F172A"
                                   LineHeight="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Total Applicants -->
                    <Border Grid.Row="0" Grid.Column="1" 
                            BackgroundColor="White" 
                            StrokeThickness="0" 
                            Padding="16,18" 
                            StrokeShape="RoundRectangle 20">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="12" Opacity="0.08"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Applicants" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="13" 
                                       TextColor="#64748B" 
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" 
                                        WidthRequest="36" 
                                        HeightRequest="36" 
                                        StrokeShape="RoundRectangle 11" 
                                        StrokeThickness="0" 
                                        BackgroundColor="#ECFDF5">
                                    <Label Text="&#xf0c0;" 
                                           FontFamily="FASolid" 
                                           FontSize="16" 
                                           TextColor="#10B981" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <Label x:Name="TotalApplicantsLabel" 
                                   Text="0" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="32" 
                                   TextColor="#0F172A"
                                   LineHeight="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Pending Review -->
                    <Border Grid.Row="1" Grid.Column="0" 
                            BackgroundColor="White" 
                            StrokeThickness="0" 
                            Padding="16,18" 
                            StrokeShape="RoundRectangle 20">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="12" Opacity="0.08"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Pending" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="13" 
                                       TextColor="#64748B" 
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" 
                                        WidthRequest="36" 
                                        HeightRequest="36" 
                                        StrokeShape="RoundRectangle 11" 
                                        StrokeThickness="0" 
                                        BackgroundColor="#FEF3C7">
                                    <Label Text="&#xf017;" 
                                           FontFamily="FASolid" 
                                           FontSize="16" 
                                           TextColor="#F59E0B" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <Label x:Name="PendingCountLabel" 
                                   Text="0" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="32" 
                                   TextColor="#0F172A"
                                   LineHeight="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Accepted (Hired) -->
                    <Border Grid.Row="1" Grid.Column="1" 
                            BackgroundColor="White" 
                            StrokeThickness="0" 
                            Padding="16,18" 
                            StrokeShape="RoundRectangle 20">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="12" Opacity="0.08"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Hired" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="13" 
                                       TextColor="#64748B" 
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" 
                                        WidthRequest="36" 
                                        HeightRequest="36" 
                                        StrokeShape="RoundRectangle 11" 
                                        StrokeThickness="0" 
                                        BackgroundColor="#DBEAFE">
                                    <Label Text="&#xf058;" 
                                           FontFamily="FASolid" 
                                           FontSize="16" 
                                           TextColor="#3B82F6" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <Label x:Name="AcceptedCountLabel" 
                                   Text="0" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="32" 
                                   TextColor="#0F172A"
                                   LineHeight="1"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Recent Applicants Section -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,4,0,0">
                    <Label Grid.Column="0" 
                           Text="Recent Applicants" 
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="20" 
                           TextColor="#0F172A" 
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1" 
                            Text="View All" 
                            Clicked="OnViewAllApplicantsClicked" 
                            BackgroundColor="Transparent" 
                            TextColor="{StaticResource Primary}" 
                            FontFamily="Inter"
                            FontAttributes="Bold"
                            FontSize="14"
                            Padding="12,6"/>
                </Grid>

                <!-- Loading Indicator -->
                <ActivityIndicator x:Name="LoadingIndicator" 
                                   IsRunning="True" 
                                   Color="{StaticResource Primary}" 
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center" 
                                   HeightRequest="50"
                                   WidthRequest="50"/>

                <!-- Applicants Collection View -->
                <CollectionView x:Name="ApplicantsCollectionView" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="40,50" Spacing="14" HorizontalOptions="Center" VerticalOptions="Center">
                            <Border WidthRequest="72" 
                                    HeightRequest="72" 
                                    StrokeThickness="0" 
                                    BackgroundColor="#F1F5F9" 
                                    StrokeShape="RoundRectangle 20"
                                    HorizontalOptions="Center">
                                <Label Text="&#xf0c0;" 
                                       FontFamily="FASolid" 
                                       FontSize="32" 
                                       TextColor="#94A3B8" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="No applicants yet" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="18" 
                                   TextColor="#0F172A" 
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="When candidates apply to your jobs,&#x0a;they'll appear here" 
                                   FontFamily="Inter"
                                   FontSize="14" 
                                   TextColor="#64748B" 
                                   HorizontalTextAlignment="Center"
                                   LineHeight="1.5"
                                   MaximumWidthRequest="260"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 20" 
                                    StrokeThickness="0" 
                                    BackgroundColor="White" 
                                    Margin="0,0,0,12" 
                                    Padding="16">
                                <Border.Shadow>
                                    <Shadow Brush="#64748B" Offset="0,4" Radius="20" Opacity="0.06"/>
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnApplicantTapped" CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="56, *, Auto" ColumnSpacing="14">
                                    <!-- Avatar -->
                                    <Border Grid.Column="0" 
                                            WidthRequest="56" 
                                            HeightRequest="56" 
                                            StrokeShape="RoundRectangle 16" 
                                            StrokeThickness="2"
                                            Stroke="#F1F5F9"
                                            BackgroundColor="#F8FAFC" 
                                            VerticalOptions="Center">
                                        <Grid>
                                            <Label Text="&#xf007;" 
                                                   FontFamily="FASolid" 
                                                   FontSize="24" 
                                                   TextColor="#CBD5E1" 
                                                   HorizontalOptions="Center" 
                                                   VerticalOptions="Center"/>
                                            <Border StrokeShape="RoundRectangle 16" 
                                                    StrokeThickness="0"
                                                    BackgroundColor="Transparent">
                                                <Image Source="{Binding seekerPhoto}" 
                                                       Aspect="AspectFill"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Content -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                        <Label Text="{Binding seekerName}" 
                                               FontFamily="Inter"
                                               FontAttributes="Bold"
                                               FontSize="16" 
                                               TextColor="#0F172A"
                                               LineHeight="1.2"/>
                                        <Label Text="{Binding jobTitle, StringFormat='Applied for: {0}'}" 
                                               FontFamily="Inter"
                                               FontSize="13" 
                                               TextColor="#64748B" 
                                               MaxLines="1" 
                                               LineBreakMode="TailTruncation"/>
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="&#xf017;" 
                                                   FontFamily="FASolid" 
                                                   FontSize="11" 
                                                   TextColor="#94A3B8"
                                                   VerticalOptions="Center"/>
                                            <Label Text="{Binding appliedAt, StringFormat='{0:MMM dd, yyyy}'}" 
                                                   FontFamily="Inter"
                                                   FontSize="12" 
                                                   TextColor="#94A3B8"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Status Badge -->
                                    <Border Grid.Column="2" 
                                            Padding="12,6" 
                                            StrokeThickness="0" 
                                            StrokeShape="RoundRectangle 12" 
                                            VerticalOptions="Center">
                                        <Border.Triggers>
                                            <!-- Pending Status -->
                                            <DataTrigger TargetType="Border" Binding="{Binding status}" Value="Pending">
                                                <Setter Property="BackgroundColor" Value="#FEF3C7"/>
                                            </DataTrigger>
                                            <!-- Accepted Status -->
                                            <DataTrigger TargetType="Border" Binding="{Binding status}" Value="Accepted">
                                                <Setter Property="BackgroundColor" Value="#D1FAE5"/>
                                            </DataTrigger>
                                            <!-- Rejected Status -->
                                            <DataTrigger TargetType="Border" Binding="{Binding status}" Value="Rejected">
                                                <Setter Property="BackgroundColor" Value="#FEE2E2"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        
                                        <Label Text="{Binding status}" 
                                               FontFamily="Inter"
                                               FontAttributes="Bold"
                                               FontSize="12">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding status}" Value="Pending">
                                                    <Setter Property="TextColor" Value="#92400E"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding status}" Value="Accepted">
                                                    <Setter Property="TextColor" Value="#065F46"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding status}" Value="Rejected">
                                                    <Setter Property="TextColor" Value="#991B1B"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Bottom Navigation -->
        <components:BottomNav Grid.Row="1" x:Name="BottomNavigation" ActivePage="dashboard"/>
    </Grid>
</base:BasePage>

<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             xmlns:components="clr-namespace:BagoScoutApp.Pages.AuthUser.Seeker.Components"
             x:Class="BagoScoutApp.Pages.AuthUser.Seeker.SDashboardPage"
             Title="Dashboard"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8FAFC">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Main Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16,20,24" Spacing="24">
                <!-- Welcome Section -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,8,0,4">
                    <VerticalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                        <Label x:Name="WelcomeLabel"
                               Text="Welcome back! 👋" 
                               FontFamily="Inter"
                               FontAttributes="Bold"
                               FontSize="28"
                               TextColor="#0F172A"
                               LineHeight="1.2"/>
                        <Label Text="Find your next dream opportunity" 
                               FontFamily="Inter"
                               FontSize="15"
                               TextColor="#64748B"
                               LineHeight="1.4"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            WidthRequest="52"
                            HeightRequest="52"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}"
                            VerticalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="#6C63FF" Offset="0,4" Radius="12" Opacity="0.25"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBuildingIconTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="&#xf007;" 
                               FontFamily="FASolid"
                               FontSize="22" 
                               TextColor="White"
                               HorizontalOptions="Center" 
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Stats Cards Section -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="14">
                    <!-- Card 1: Applications -->
                    <Border Grid.Column="0"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            Padding="16,18"
                            StrokeShape="RoundRectangle 20">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="12" Opacity="0.08"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" 
                                       Text="Applied Jobs" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="13" 
                                       TextColor="#64748B" 
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" 
                                        WidthRequest="36" 
                                        HeightRequest="36" 
                                        StrokeShape="RoundRectangle 11" 
                                        StrokeThickness="0" 
                                        BackgroundColor="#EEF2FF">
                                    <Label Text="&#xf0b1;" 
                                           FontFamily="FASolid" 
                                           FontSize="16" 
                                           TextColor="#6366F1" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <Label x:Name="AppliedCountLabel" 
                                   Text="0" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="32" 
                                   TextColor="#0F172A"
                                   LineHeight="1"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Card 2: Profile Status -->
                    <Border Grid.Column="1"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            Padding="16,18"
                            StrokeShape="RoundRectangle 20">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="12" Opacity="0.08"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" 
                                       Text="Profile" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="13" 
                                       TextColor="#64748B" 
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" 
                                        WidthRequest="36" 
                                        HeightRequest="36" 
                                        StrokeShape="RoundRectangle 11" 
                                        StrokeThickness="0" 
                                        BackgroundColor="#ECFDF5">
                                    <Label Text="&#xf058;" 
                                           FontFamily="FASolid" 
                                           FontSize="16" 
                                           TextColor="#10B981" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <Label x:Name="ProfileStatusLabel" 
                                   Text="Complete" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="18" 
                                   TextColor="#10B981"
                                   LineHeight="1.2"
                                   Margin="0,4,0,0"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Job Preferences Section -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="18"
                        StrokeShape="RoundRectangle 20">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,2" Radius="12" Opacity="0.08"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <!-- Header -->
                        <Grid ColumnDefinitions="*, Auto">
                            <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                                <Label Text="&#xf1de;" 
                                       FontFamily="FASolid" 
                                       FontSize="18" 
                                       TextColor="#6C63FF"
                                       VerticalOptions="Center"/>
                                <Label Text="Job Preferences" 
                                       FontFamily="Inter"
                                       FontAttributes="Bold"
                                       FontSize="18" 
                                       TextColor="#0F172A"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Button Grid.Column="1"
                                    Text="Edit"
                                    FontFamily="Inter"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    TextColor="White"
                                    BackgroundColor="#6C63FF"
                                    CornerRadius="10"
                                    Padding="14,8"
                                    Clicked="OnEditPreferencesClicked">
                                <Button.Shadow>
                                    <Shadow Brush="#6C63FF" Offset="0,2" Radius="8" Opacity="0.25"/>
                                </Button.Shadow>
                            </Button>
                        </Grid>
                        
                        <!-- Preferences Display -->
                        <VerticalStackLayout x:Name="PreferencesContainer" Spacing="10">
                            <Label Text="Loading preferences..." 
                                   FontFamily="Inter"
                                   FontSize="14" 
                                   TextColor="#64748B"
                                   HorizontalTextAlignment="Center"
                                   Margin="0,10"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Nearby Jobs Title -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,4,0,0">
                    <Label Grid.Column="0"
                           x:Name="RecommendedLabel"
                           Text="Recommended Jobs for You" 
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="20" 
                           TextColor="#0F172A" 
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1" 
                            Text="View All" 
                            Clicked="OnViewAllJobsClicked" 
                            BackgroundColor="Transparent" 
                            TextColor="{StaticResource Primary}" 
                            FontFamily="Inter"
                            FontAttributes="Bold"
                            FontSize="14"
                            Padding="12,6"/>
                </Grid>

                <!-- Loading Indicator -->
                <VerticalStackLayout x:Name="LoadingContainer" 
                                     IsVisible="False" 
                                     HorizontalOptions="Center" 
                                     Spacing="14"
                                     Margin="0,20">
                    <ActivityIndicator x:Name="LoadingIndicator" 
                                       IsRunning="False"
                                       Color="#6C63FF" 
                                       HeightRequest="50"
                                       WidthRequest="50"/>
                    <Label Text="Loading nearby jobs..." 
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="15" 
                           TextColor="#64748B"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Jobs Collection View -->
                <CollectionView x:Name="JobsCollectionView"
                                SelectionMode="None"
                                IsVisible="True"
                                Margin="0,0,0,10">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="40,50" Spacing="14" HorizontalOptions="Center" VerticalOptions="Center">
                            <Border WidthRequest="72" 
                                    HeightRequest="72" 
                                    StrokeThickness="0" 
                                    BackgroundColor="#F1F5F9" 
                                    StrokeShape="RoundRectangle 20"
                                    HorizontalOptions="Center">
                                <Label Text="&#xf002;" 
                                       FontFamily="FASolid" 
                                       FontSize="32" 
                                       TextColor="#94A3B8" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="No active jobs found" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="18" 
                                   TextColor="#0F172A" 
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Try checking back later or explore&#x0a;more jobs in the Jobs tab" 
                                   FontFamily="Inter"
                                   FontSize="14" 
                                   TextColor="#64748B" 
                                   HorizontalTextAlignment="Center"
                                   LineHeight="1.5"
                                   MaximumWidthRequest="260"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0"
                                    BackgroundColor="White"
                                    Margin="0,0,0,12"
                                    Padding="18">
                                <Border.Shadow>
                                    <Shadow Brush="#64748B" Offset="0,4" Radius="16" Opacity="0.06"/>
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnJobTapped" CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="10">
                                    <!-- Header -->
                                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                                            <Label Text="{Binding title}" 
                                                   FontFamily="Inter"
                                                   FontAttributes="Bold"
                                                   FontSize="16"
                                                   TextColor="#0F172A"
                                                   LineHeight="1.2"/>
                                            <Label Text="{Binding company}" 
                                                   FontFamily="Inter"
                                                   FontAttributes="Bold"
                                                   FontSize="14"
                                                   TextColor="{StaticResource Primary}"/>
                                        </VerticalStackLayout>
                                        <!-- Distance Badge -->
                                        <Border Grid.Column="1" 
                                                Padding="10,5" 
                                                BackgroundColor="#EEF2FF" 
                                                StrokeThickness="0" 
                                                StrokeShape="RoundRectangle 10"
                                                VerticalOptions="Start">
                                            <Label Text="Nearby" 
                                                   FontFamily="Inter"
                                                   FontSize="12" 
                                                   TextColor="#6366F1" 
                                                   FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>

                                    <!-- Location -->
                                    <HorizontalStackLayout Grid.Row="1" Spacing="6">
                                        <Label Text="&#xf3c5;" 
                                               FontFamily="FASolid" 
                                               FontSize="12" 
                                               TextColor="#94A3B8"
                                               VerticalOptions="Center"/>
                                        <Label Text="{Binding address}" 
                                               FontFamily="Inter"
                                               FontSize="13" 
                                               TextColor="#64748B"/>
                                    </HorizontalStackLayout>

                                    <!-- Badges -->
                                    <FlexLayout Grid.Row="2" Wrap="Wrap" Direction="Row" AlignItems="Center" JustifyContent="Start">
                                        <!-- Job Type Badge -->
                                        <Border Padding="12,6" 
                                                BackgroundColor="#EEF2FF" 
                                                StrokeThickness="0" 
                                                StrokeShape="RoundRectangle 12" 
                                                Margin="0,0,8,0">
                                            <Label Text="{Binding jobType}" 
                                                   FontFamily="Inter"
                                                   FontSize="12" 
                                                   TextColor="#4F46E5" 
                                                   FontAttributes="Bold"/>
                                        </Border>
                                        <!-- Salary Badge -->
                                        <Border Padding="12,6" 
                                                BackgroundColor="#ECFDF5" 
                                                StrokeThickness="0" 
                                                StrokeShape="RoundRectangle 12" 
                                                Margin="0,0,8,0">
                                            <Label Text="{Binding salaryRange}" 
                                                   FontFamily="Inter"
                                                   FontSize="12" 
                                                   TextColor="#059669" 
                                                   FontAttributes="Bold"/>
                                        </Border>
                                    </FlexLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Bottom Navigation -->
        <components:BottomNav Grid.Row="1" x:Name="BottomNavigation" ActivePage="dashboard"/>
    </Grid>
</base:BasePage>

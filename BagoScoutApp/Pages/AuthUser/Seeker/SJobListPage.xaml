<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             xmlns:components="clr-namespace:BagoScoutApp.Pages.AuthUser.Seeker.Components"
             x:Class="BagoScoutApp.Pages.AuthUser.Seeker.SJobListPage"
             Title="Job Opportunities"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8FAFC">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Top Bar with Back Button -->
        <Grid Grid.Row="0" BackgroundColor="#6C63FF" Padding="16,12">
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="&#xf053;"
                        FontFamily="FASolid"
                        FontSize="16"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        WidthRequest="40"
                        HeightRequest="40"
                        Clicked="OnBackClicked"/>
                <Label Grid.Column="1"
                       Text="Job Opportunities"
                       FontFamily="Inter"
                       FontAttributes="Bold"
                       FontSize="18"
                       TextColor="White"
                       VerticalOptions="Center"
                       HorizontalOptions="Start"
                       Margin="4,0,0,0"/>
                <Button Grid.Column="2"
                        Text="&#xf279;"
                        FontFamily="FASolid"
                        FontSize="16"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        WidthRequest="40"
                        HeightRequest="40"
                        Clicked="OnMapViewClicked"/>
            </Grid>
        </Grid>
 
        <!-- Job Listings Content -->
        <Grid Grid.Row="1" Padding="20,16,20,20">
            <Grid RowDefinitions="Auto, Auto, *" RowSpacing="14">
                <!-- Search Entry -->
                <Border Grid.Row="0"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        Padding="14,0"
                        HeightRequest="50">
                    <Border.Shadow>
                        <Shadow Brush="#64748B" Offset="0,2" Radius="12" Opacity="0.06"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Grid.Column="0" Text="&#xf002;" FontFamily="FASolid" FontSize="15" TextColor="#94A3B8" VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Entry Grid.Column="1" 
                               x:Name="SearchEntry" 
                               Placeholder="Search jobs..." 
                               PlaceholderColor="#94A3B8"
                               FontFamily="Inter"
                               FontSize="14"
                               TextColor="#0F172A"
                               VerticalOptions="Center"
                               TextChanged="OnSearchTextChanged"/>
                    </Grid>
                </Border>
 
                <!-- Filter Scroll -->
                <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8" Padding="0,4">
                        <Button x:Name="AllFilterBtn" 
                                Text="All" 
                                Clicked="OnFilterClicked" 
                                CommandParameter="" 
                                BackgroundColor="#6C63FF" 
                                TextColor="White" 
                                CornerRadius="14" 
                                HeightRequest="40" 
                                Padding="18,0" 
                                FontFamily="Inter"
                                FontSize="12" 
                                FontAttributes="Bold"/>
                        <Button x:Name="FtFilterBtn" 
                                Text="Full-Time" 
                                Clicked="OnFilterClicked" 
                                CommandParameter="Full-Time" 
                                BackgroundColor="White" 
                                TextColor="#0F172A" 
                                BorderColor="#E2E8F0" 
                                BorderWidth="1" 
                                CornerRadius="14" 
                                HeightRequest="40" 
                                Padding="18,0" 
                                FontFamily="Inter"
                                FontSize="12" 
                                FontAttributes="Bold"/>
                        <Button x:Name="PtFilterBtn" 
                                Text="Part-Time" 
                                Clicked="OnFilterClicked" 
                                CommandParameter="Part-Time" 
                                BackgroundColor="White" 
                                TextColor="#0F172A" 
                                BorderColor="#E2E8F0" 
                                BorderWidth="1" 
                                CornerRadius="14" 
                                HeightRequest="40" 
                                Padding="18,0" 
                                FontFamily="Inter"
                                FontSize="12" 
                                FontAttributes="Bold"/>
                        <Button x:Name="ContractFilterBtn" 
                                Text="Contract" 
                                Clicked="OnFilterClicked" 
                                CommandParameter="Contract" 
                                BackgroundColor="White" 
                                TextColor="#0F172A" 
                                BorderColor="#E2E8F0" 
                                BorderWidth="1" 
                                CornerRadius="14" 
                                HeightRequest="40" 
                                Padding="18,0" 
                                FontFamily="Inter"
                                FontSize="12" 
                                FontAttributes="Bold"/>
                        <Button x:Name="InternFilterBtn" 
                                Text="Internship" 
                                Clicked="OnFilterClicked" 
                                CommandParameter="Internship" 
                                BackgroundColor="White" 
                                TextColor="#0F172A" 
                                BorderColor="#E2E8F0" 
                                BorderWidth="1" 
                                CornerRadius="14" 
                                HeightRequest="40" 
                                Padding="18,0" 
                                FontFamily="Inter"
                                FontSize="12" 
                                FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </ScrollView>
 
                <!-- Jobs List -->
                <CollectionView Grid.Row="2" x:Name="JobsCollectionView" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="40,50" Spacing="14" HorizontalOptions="Center" VerticalOptions="Center">
                            <Border WidthRequest="72" 
                                    HeightRequest="72" 
                                    StrokeThickness="0" 
                                    BackgroundColor="#F1F5F9" 
                                    StrokeShape="RoundRectangle 20"
                                    HorizontalOptions="Center">
                                <Label Text="&#xf002;" 
                                       FontFamily="FASolid" 
                                       FontSize="32" 
                                       TextColor="#94A3B8" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="No jobs found" 
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="18" 
                                   TextColor="#0F172A" 
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Try adjusting your search or filters" 
                                   FontFamily="Inter"
                                   FontSize="14" 
                                   TextColor="#64748B" 
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0"
                                    BackgroundColor="White"
                                    Margin="0,0,0,14"
                                    Padding="20">
                                <Border.Shadow>
                                    <Shadow Brush="#64748B" Offset="0,4" Radius="16" Opacity="0.06"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="14">
                                    <!-- Header: Job Title & Company -->
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding title}" 
                                               FontFamily="Inter"
                                               FontAttributes="Bold"
                                               FontSize="18" 
                                               TextColor="#0F172A" 
                                               LineHeight="1.2"
                                               MaxLines="2" 
                                               LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding company}" 
                                               FontFamily="Inter"
                                               FontAttributes="Bold"
                                               FontSize="15" 
                                               TextColor="#6C63FF" 
                                               MaxLines="1" 
                                               LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>
 
                                    <!-- Location -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Border WidthRequest="32" 
                                                HeightRequest="32" 
                                                StrokeShape="RoundRectangle 10" 
                                                StrokeThickness="0" 
                                                BackgroundColor="#F1F5F9"
                                                VerticalOptions="Center">
                                            <Label Text="&#xf3c5;" 
                                                   FontFamily="FASolid" 
                                                   FontSize="14" 
                                                   TextColor="#64748B" 
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        <Label Text="{Binding address}" 
                                               FontFamily="Inter"
                                               FontSize="14" 
                                               TextColor="#64748B"
                                               VerticalOptions="Center" 
                                               MaxLines="1" 
                                               LineBreakMode="TailTruncation"/>
                                    </HorizontalStackLayout>
 
                                    <!-- Job Description -->
                                    <Label Text="{Binding description}" 
                                           FontFamily="Inter"
                                           FontSize="14" 
                                           TextColor="#64748B"
                                           LineHeight="1.5"
                                           Margin="0,4,0,0"/>
 
                                    <!-- Badges Row -->
                                    <FlexLayout Wrap="Wrap" Direction="Row" AlignItems="Center" JustifyContent="Start" Margin="0,6,0,0">
                                        <!-- Job Type Badge -->
                                        <Border Padding="12,7" 
                                                BackgroundColor="#EEF2FF" 
                                                StrokeThickness="0" 
                                                StrokeShape="RoundRectangle 10" 
                                                Margin="0,0,8,8">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="&#xf0b1;" 
                                                       FontFamily="FASolid" 
                                                       FontSize="11" 
                                                       TextColor="#4F46E5" 
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding jobType}" 
                                                       FontFamily="Inter"
                                                       FontSize="12" 
                                                       TextColor="#4F46E5" 
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>
                                        
                                        <!-- Salary Badge -->
                                        <Border Padding="12,7" 
                                                BackgroundColor="#ECFDF5" 
                                                StrokeThickness="0" 
                                                StrokeShape="RoundRectangle 10" 
                                                Margin="0,0,8,8">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="&#xf155;" 
                                                       FontFamily="FASolid" 
                                                       FontSize="11" 
                                                       TextColor="#059669" 
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding salaryRange}" 
                                                       FontFamily="Inter"
                                                       FontSize="12" 
                                                       TextColor="#059669" 
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>
                                        
                                        <!-- Distance Badge -->
                                        <Border Padding="12,7" 
                                                BackgroundColor="#DBEAFE" 
                                                StrokeThickness="0" 
                                                StrokeShape="RoundRectangle 10" 
                                                Margin="0,0,8,8" 
                                                IsVisible="{Binding hasDistance}">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="&#xf3c5;" 
                                                       FontFamily="FASolid" 
                                                       FontSize="11" 
                                                       TextColor="#0369A1" 
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding distanceDisplay}" 
                                                       FontFamily="Inter"
                                                       FontSize="12" 
                                                       TextColor="#0369A1" 
                                                       FontAttributes="Bold" 
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>
                                        
                                        <!-- Experience Level Badge -->
                                        <Border Padding="12,7" 
                                                BackgroundColor="#FEF3C7" 
                                                StrokeThickness="0" 
                                                StrokeShape="RoundRectangle 10" 
                                                Margin="0,0,8,8"
                                                IsVisible="{Binding hasExperienceLevel}">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="&#xf19d;" 
                                                       FontFamily="FASolid" 
                                                       FontSize="11" 
                                                       TextColor="#D97706" 
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding experienceLevel}" 
                                                       FontFamily="Inter"
                                                       FontSize="12" 
                                                       TextColor="#D97706" 
                                                       FontAttributes="Bold" 
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>
                                    </FlexLayout>
 
                                    <!-- Requirements Section -->
                                    <VerticalStackLayout Spacing="8" 
                                                         IsVisible="{Binding hasRequirements}"
                                                         Margin="0,4,0,0">
                                        <Label Text="Requirements" 
                                               FontFamily="Inter"
                                               FontAttributes="Bold"
                                               FontSize="14" 
                                               TextColor="#0F172A"/>
                                        <Label Text="{Binding requirements}" 
                                               FontFamily="Inter"
                                               FontSize="13" 
                                               TextColor="#64748B"
                                               LineHeight="1.5"/>
                                    </VerticalStackLayout>
 
                                    <!-- View on Map Link -->
                                    <Border Padding="14,12" 
                                            BackgroundColor="#F8FAFC" 
                                            StrokeThickness="1" 
                                            StrokeShape="RoundRectangle 12" 
                                            Stroke="#E2E8F0"
                                            Margin="0,6,0,0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnJobItemTapped" CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                            <Label Text="&#xf3c5;" 
                                                   FontFamily="FASolid" 
                                                   FontSize="14" 
                                                   TextColor="#6C63FF" 
                                                   VerticalOptions="Center"/>
                                            <Label Text="View on Map" 
                                                   FontFamily="Inter"
                                                   FontAttributes="Bold"
                                                   FontSize="14" 
                                                   TextColor="#6C63FF"
                                                   VerticalOptions="Center"/>
                                            <Label Text="&#xf054;" 
                                                   FontFamily="FASolid" 
                                                   FontSize="12" 
                                                   TextColor="#6C63FF" 
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
 
                <!-- Loading Spinner -->
                <VerticalStackLayout x:Name="LoadingContainer"
                                     Grid.Row="2"
                                     IsVisible="False" 
                                     HorizontalOptions="Center" 
                                     VerticalOptions="Center"
                                     Spacing="14">
                    <ActivityIndicator x:Name="LoadingIndicator" 
                                       IsRunning="False"
                                       Color="#6C63FF" 
                                       HeightRequest="50"
                                       WidthRequest="50"/>
                    <Label Text="Loading jobs..." 
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="15" 
                           TextColor="#64748B"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>
        
        <!-- Bottom Navigation -->
        <components:BottomNav Grid.Row="2" x:Name="BottomNavigation" ActivePage="jobs"/>
    </Grid>
</base:BasePage>

<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             xmlns:components="clr-namespace:BagoScoutApp.Pages.AuthUser.Seeker.Components"
             x:Class="BagoScoutApp.Pages.AuthUser.Seeker.SJobsPage"
             Title="Find Jobs"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Secondary}">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Main Content -->
        <Grid Grid.Row="0">
            <!-- Full viewport Map Wrapper Container -->
            <components:JobMapControl x:Name="JobMap" 
                                      ZIndex="1"
                                      JobSelected="OnJobSelectedOnMap" 
                                      ViewDetailsClicked="OnViewDetailsClickedOnMap"/>

            <!-- Floating Job List Button -->
            <Button x:Name="JobListButton"
                    ZIndex="11"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Text="&#xf0c9;"
                    FontFamily="FASolid"
                    FontSize="20"
                    Padding="0"
                    HorizontalOptions="Start"
                    VerticalOptions="Start"
                    Margin="16"
                    Clicked="OnJobListClicked">
                <Button.Shadow>
                    <Shadow Offset="0,4" Radius="6" Brush="#000000" Opacity="0.15"/>
                </Button.Shadow>
            </Button>

            <!-- Floating My Location Button -->
            <Button x:Name="MyLocationButton"
                    ZIndex="11"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    BackgroundColor="White"
                    TextColor="{StaticResource PrimaryDark}"
                    Text="&#xf124;"
                    FontFamily="FASolid"
                    FontSize="18"
                    Padding="0"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="16"
                    Clicked="OnMyLocationClicked">
                <Button.Shadow>
                    <Shadow Offset="0,4" Radius="6" Brush="#000000" Opacity="0.15"/>
                </Button.Shadow>
            </Button>

            <!-- Loading Spinner (overlay on Map) -->
            <ActivityIndicator x:Name="LoadingIndicator" 
                               ZIndex="5"
                               IsRunning="False" 
                               IsVisible="False"
                               Color="{StaticResource Primary}" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center"
                               HeightRequest="50"/>

            <!-- Custom Job Details Slide-Up Panel / Overlay -->
            <Grid x:Name="DetailsOverlay" ZIndex="20" BackgroundColor="#80000000" IsVisible="False">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCloseDetailsTapped"/>
                </Grid.GestureRecognizers>
                
                <Border VerticalOptions="End"
                        HeightRequest="520"
                        StrokeShape="RoundRectangle 24,24,0,0"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        Padding="24">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer /> <!-- Intercept tap events to prevent closing -->
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto, *, Auto" RowSpacing="16">
                        <!-- Top Close Handle & Title -->
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label x:Name="DetailTitleLabel" Text="Job Title" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Label x:Name="DetailCompanyLabel" Text="Company" FontSize="14" TextColor="{StaticResource Primary}" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1" 
                                    Text="&#xf00d;" 
                                    FontFamily="FASolid"
                                    FontSize="16" 
                                    TextColor="{StaticResource Gray500}" 
                                    BackgroundColor="Transparent" 
                                    Clicked="OnCloseDetailsTapped"
                                    WidthRequest="40"
                                    HeightRequest="40"/>
                        </Grid>

                        <!-- Scrollable details and application fields -->
                        <ScrollView Grid.Row="1">
                            <VerticalStackLayout Spacing="16">
                                <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                    <Border Grid.Column="0" BackgroundColor="{StaticResource Secondary}" Padding="12" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Salary" FontSize="11" TextColor="{StaticResource Gray500}" FontAttributes="Bold"/>
                                            <Label x:Name="DetailSalaryLabel" Text="-" FontSize="13" TextColor="{StaticResource PrimaryDark}" FontAttributes="Bold"/>
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Grid.Column="1" BackgroundColor="{StaticResource Secondary}" Padding="12" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Job Type" FontSize="11" TextColor="{StaticResource Gray500}" FontAttributes="Bold"/>
                                            <Label x:Name="DetailTypeLabel" Text="-" FontSize="13" TextColor="{StaticResource Primary}" FontAttributes="Bold"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>

                                <Label x:Name="DetailAddressLabel" Text="Location" FontSize="13" TextColor="{StaticResource Gray500}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="&#xf3c5; " FontFamily="FASolid"/>
                                            <Span Text="-"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label Text="Job Description" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Label x:Name="DetailDescLabel" Text="Description content" FontSize="13" TextColor="{StaticResource Gray600}"/>

                                <Label Text="Requirements" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Label x:Name="DetailReqLabel" Text="Requirements content" FontSize="13" TextColor="{StaticResource Gray600}"/>

                                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,10"/>

                                <!-- Cover Letter Input -->
                                <Label Text="Cover Letter (Optional)" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="White" Padding="12,4">
                                    <Editor x:Name="CoverLetterEditor" 
                                            Placeholder="Explain why you are a good fit for this role..." 
                                            PlaceholderColor="{StaticResource Gray400}"
                                            HeightRequest="100" 
                                            FontSize="13" 
                                            TextColor="{StaticResource PrimaryDark}"/>
                                </Border>
                            </VerticalStackLayout>
                        </ScrollView>

                        <!-- Apply Button -->
                        <Grid Grid.Row="2" ColumnDefinitions="*">
                            <Button Grid.Column="0" 
                                    x:Name="ApplyBtn"
                                    Text="Apply to Position" 
                                    BackgroundColor="{StaticResource Primary}" 
                                    TextColor="White" 
                                    CornerRadius="12" 
                                    HeightRequest="56" 
                                    FontAttributes="Bold"
                                    Clicked="OnSubmitApplicationClicked"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!-- Bottom Navigation -->
        <components:BottomNav Grid.Row="1" x:Name="BottomNavigation" ActivePage="jobs"/>
    </Grid>
</base:BasePage>

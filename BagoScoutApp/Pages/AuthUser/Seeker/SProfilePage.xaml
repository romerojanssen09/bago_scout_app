<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             xmlns:components="clr-namespace:BagoScoutApp.Pages.AuthUser.Seeker.Components"
             x:Class="BagoScoutApp.Pages.AuthUser.Seeker.SProfilePage"
             Title="Profile"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Secondary}">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Main Content Container (Row 0) -->
        <Grid Grid.Row="0">
            <!-- Main Scrollable Content -->
            <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">
                <!-- Title Header -->
                <Label Text="My Profile" 
                       FontSize="24" 
                       FontAttributes="Bold"
                       TextColor="{StaticResource PrimaryDark}"
                       Margin="0,10,0,0"/>
 
                <!-- Profile Photo Card -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}"
                        BackgroundColor="White"
                        Padding="20">
                    <Border.Shadow>
                        <Shadow Offset="0,4" Radius="10" Brush="#0F172A" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                        <!-- Avatar / Photo -->
                        <Grid HorizontalOptions="Center">
                            <Border x:Name="ProfilePhotoBorder"
                                    WidthRequest="100"
                                    HeightRequest="100"
                                    StrokeShape="RoundRectangle 50"
                                    StrokeThickness="3"
                                    Stroke="{StaticResource Primary}"
                                    BackgroundColor="{StaticResource Secondary}"
                                    HorizontalOptions="Center">
                                <Grid>
                                    <Image x:Name="ProfileImage"
                                           Aspect="AspectFill"
                                           IsVisible="False"/>
                                    <Label x:Name="ProfilePlaceholder"
                                           Text="&#xf007;"
                                           FontFamily="FASolid"
                                           FontSize="44"
                                           TextColor="{StaticResource Primary}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                            <Button Text="&#xf030;"
                                    FontFamily="FASolid"
                                    Clicked="OnChangePhotoClicked"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    CornerRadius="20"
                                    BackgroundColor="{StaticResource PrimaryDark}"
                                    TextColor="White"
                                    FontSize="14"
                                    HorizontalOptions="End"
                                    VerticalOptions="End"
                                    TranslationX="10"
                                    TranslationY="10">
                                <Button.Shadow>
                                    <Shadow Offset="0,2" Radius="4" Brush="#000000" Opacity="0.15"/>
                                </Button.Shadow>
                            </Button>
                        </Grid>
                        
                        <Label x:Name="UserFullNameLabel"
                               Text="-"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"
                               HorizontalOptions="Center"/>
                        
                        <Label x:Name="UserEmailLabel"
                               Text="-"
                               FontSize="14"
                               TextColor="{StaticResource Gray500}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
 
                <!-- Personal Info Fields Card -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}"
                        BackgroundColor="White"
                        Padding="20">
                    <Border.Shadow>
                        <Shadow Offset="0,4" Radius="10" Brush="#0F172A" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Personal Information" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"/>
                        
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <!-- First Name -->
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="First Name *" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                    <Entry x:Name="FirstNameEntry" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                            
                            <!-- Last Name -->
                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="Last Name *" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                    <Entry x:Name="LastNameEntry" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
 
                        <!-- Phone Number -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Phone Number" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                            <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                <Entry x:Name="PhoneNumberEntry" Keyboard="Telephone" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>
                        
                        <Button x:Name="SaveProfileBtn"
                                Text="Save Profile"
                                Clicked="OnSaveProfileClicked"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="56"
                                FontAttributes="Bold"
                                FontSize="15"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Border>
 
                <!-- Skills Chip Card -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}"
                        BackgroundColor="White"
                        Padding="20">
                    <Border.Shadow>
                        <Shadow Offset="0,4" Radius="10" Brush="#0F172A" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Skills" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"/>
                        
                        <!-- Add Custom Skill Field -->
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                <Entry x:Name="CustomSkillEntry" Placeholder="Add skill (e.g. C#)" PlaceholderColor="{StaticResource Gray400}" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                            </Border>
                            <Button Grid.Column="1"
                                    Text="Add"
                                    Clicked="OnAddCustomSkillClicked"
                                    BackgroundColor="{StaticResource PrimaryDark}"
                                    TextColor="White"
                                    CornerRadius="12"
                                    WidthRequest="80"
                                    HeightRequest="48"
                                    FontAttributes="Bold"
                                    FontSize="14"/>
                        </Grid>
 
                        <!-- Skills Container (chips wrap layout) -->
                        <FlexLayout x:Name="SkillsFlexLayout" 
                                    Wrap="Wrap" 
                                    Direction="Row" 
                                    AlignItems="Center" 
                                    JustifyContent="Start"
                                    Margin="0,5,0,0">
                            <!-- Skill chips populated in C# dynamically -->
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>
 
                <!-- Education Card -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}"
                        BackgroundColor="White"
                        Padding="20">
                    <Border.Shadow>
                        <Shadow Offset="0,4" Radius="10" Brush="#0F172A" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Education" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryDark}"
                                   VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                    Text="+ Add"
                                    Clicked="OnAddEducationClicked"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    Padding="12,0"
                                    HeightRequest="36"
                                    FontSize="12"
                                    FontAttributes="Bold"/>
                        </Grid>
                        <VerticalStackLayout x:Name="EducationListLayout" Spacing="12">
                            <!-- Populated in C# -->
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
 
                <!-- Experience Card -->
                <Border StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}"
                        BackgroundColor="White"
                        Padding="20">
                    <Border.Shadow>
                        <Shadow Offset="0,4" Radius="10" Brush="#0F172A" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Experience" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryDark}"
                                   VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                    Text="+ Add"
                                    Clicked="OnAddExperienceClicked"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    Padding="12,0"
                                    HeightRequest="36"
                                    FontSize="12"
                                    FontAttributes="Bold"/>
                        </Grid>
                        <VerticalStackLayout x:Name="ExperienceListLayout" Spacing="12">
                            <!-- Populated in C# -->
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
 
                <!-- Logout Card -->
                <Button Text="Logout" 
                        Clicked="OnLogoutClicked"
                        BackgroundColor="#EF4444"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="56"
                        FontAttributes="Bold"
                        FontSize="15"
                        Margin="0,0,0,20"/>
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Education Form Modal Overlay -->
        <Grid x:Name="EducationFormOverlay" ZIndex="30" BackgroundColor="#80000000" IsVisible="False">
            <Border StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    VerticalOptions="End"
                    HeightRequest="520"
                    Padding="24,20">
                <Grid RowDefinitions="Auto, *, Auto" RowSpacing="16">
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                        <Label x:Name="EduFormTitleLabel" Text="Add Education" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="&#xf00d;" FontFamily="FASolid" Clicked="OnCancelEduClicked" BackgroundColor="Transparent" TextColor="{StaticResource Gray500}" FontSize="16" FontAttributes="Bold" WidthRequest="40" HeightRequest="40"/>
                    </Grid>
                    
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Spacing="16">
                            <!-- School -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="School / University *" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                    <Entry x:Name="EduSchoolEntry" Placeholder="e.g. Bago City College" PlaceholderColor="{StaticResource Gray400}" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                            
                            <!-- Degree -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Degree *" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                    <Entry x:Name="EduDegreeEntry" Placeholder="e.g. Bachelor of Science" PlaceholderColor="{StaticResource Gray400}" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                            
                            <!-- Field of Study -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Field of Study" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                    <Entry x:Name="EduFieldEntry" Placeholder="e.g. Information Technology" PlaceholderColor="{StaticResource Gray400}" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                            
                            <!-- Dates -->
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="6">
                                    <Label Text="Start Date" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                    <DatePicker x:Name="EduStartDatePicker" Format="yyyy-MM-dd" FontSize="13" TextColor="{StaticResource PrimaryDark}" HeightRequest="48"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="6">
                                    <Label Text="End Date" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                    <DatePicker x:Name="EduEndDatePicker" Format="yyyy-MM-dd" FontSize="13" TextColor="{StaticResource PrimaryDark}" HeightRequest="48"/>
                                </VerticalStackLayout>
                            </Grid>
                            
                            <!-- Description -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Description" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,8">
                                    <Editor x:Name="EduDescEditor" Placeholder="Describe your studies, achievements..." PlaceholderColor="{StaticResource Gray400}" HeightRequest="90" FontSize="13" TextColor="{StaticResource PrimaryDark}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                    
                    <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,10,0,0">
                        <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelEduClicked" BackgroundColor="{StaticResource Gray200}" TextColor="{StaticResource PrimaryDark}" CornerRadius="12" HeightRequest="56" FontAttributes="Bold"/>
                        <Button Grid.Column="1" x:Name="SaveEduBtn" Text="Save" Clicked="OnSaveEduClicked" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="12" HeightRequest="56" FontAttributes="Bold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
 
        <!-- Experience Form Modal Overlay -->
        <Grid x:Name="ExperienceFormOverlay" ZIndex="30" BackgroundColor="#80000000" IsVisible="False">
            <Border StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    VerticalOptions="End"
                    HeightRequest="550"
                    Padding="24,20">
                <Grid RowDefinitions="Auto, *, Auto" RowSpacing="16">
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                        <Label x:Name="ExpFormTitleLabel" Text="Add Experience" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="&#xf00d;" FontFamily="FASolid" Clicked="OnCancelExpClicked" BackgroundColor="Transparent" TextColor="{StaticResource Gray500}" FontSize="16" FontAttributes="Bold" WidthRequest="40" HeightRequest="40"/>
                    </Grid>
                    
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Spacing="16">
                            <!-- Job Title -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Job Title *" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                    <Entry x:Name="ExpTitleEntry" Placeholder="e.g. Senior Software Engineer" PlaceholderColor="{StaticResource Gray400}" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                            
                            <!-- Company -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Company *" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                    <Entry x:Name="ExpCompanyEntry" Placeholder="e.g. Google" PlaceholderColor="{StaticResource Gray400}" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                            
                            <!-- Location -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Location" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,0" HeightRequest="48">
                                    <Entry x:Name="ExpLocationEntry" Placeholder="e.g. Mountain View, CA" PlaceholderColor="{StaticResource Gray400}" FontSize="13" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
 
                            <!-- Current Job Checkbox -->
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <CheckBox x:Name="ExpCurrentJobCheckBox" CheckedChanged="OnCurrentJobCheckedChanged" Color="{StaticResource Primary}"/>
                                <Label Text="I am currently working in this role" VerticalOptions="Center" FontSize="13" TextColor="{StaticResource PrimaryDark}"/>
                            </HorizontalStackLayout>
                            
                            <!-- Dates -->
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="6">
                                    <Label Text="Start Date" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                    <DatePicker x:Name="ExpStartDatePicker" Format="yyyy-MM-dd" FontSize="13" TextColor="{StaticResource PrimaryDark}" HeightRequest="48"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout x:Name="ExpEndDateLayout" Grid.Column="1" Spacing="6">
                                    <Label Text="End Date" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                    <DatePicker x:Name="ExpEndDatePicker" Format="yyyy-MM-dd" FontSize="13" TextColor="{StaticResource PrimaryDark}" HeightRequest="48"/>
                                </VerticalStackLayout>
                            </Grid>
                            
                            <!-- Description -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Description" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="16,8">
                                    <Editor x:Name="ExpDescEditor" Placeholder="Describe your role, responsibilities..." PlaceholderColor="{StaticResource Gray400}" HeightRequest="90" FontSize="13" TextColor="{StaticResource PrimaryDark}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                    
                    <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,10,0,0">
                        <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelExpClicked" BackgroundColor="{StaticResource Gray200}" TextColor="{StaticResource PrimaryDark}" CornerRadius="12" HeightRequest="56" FontAttributes="Bold"/>
                        <Button Grid.Column="1" x:Name="SaveExpBtn" Text="Save" Clicked="OnSaveExpClicked" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="12" HeightRequest="56" FontAttributes="Bold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        </Grid>
        
        <!-- Bottom Navigation -->
        <components:BottomNav Grid.Row="1" x:Name="BottomNavigation" ActivePage="profile"/>
    </Grid>
</base:BasePage>

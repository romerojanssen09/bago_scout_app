<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             x:Class="BagoScoutApp.Pages.Register.RegisterSkillsPage"
             Title="Register: Skills"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Secondary}">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,52,24,32" Spacing="0">
                <!-- Close Button -->
                <Label Text="&#xf00d;" 
                       FontFamily="FASolid"
                       FontSize="18" 
                       TextColor="#94A3B8"
                       HorizontalOptions="End"
                       Margin="0,0,0,24">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseTapped"/>
                    </Label.GestureRecognizers>
                </Label>
                
                <!-- Brand -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center" Margin="0,0,0,32">
                    <Label Text="BagoScout" 
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="28" 
                           TextColor="#1C2B53"
                           HorizontalOptions="Center"/>
                    <Label Text="Almost done!" 
                           FontFamily="Inter"
                           FontSize="15" 
                           TextColor="#64748B"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
                <!-- Progress stepper -->
                <Grid Margin="0,0,0,32" HorizontalOptions="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Step dots -->
                    <Border Grid.Column="0" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#10B981">
                        <Label Text="&#x2713;" FontFamily="FASolid" FontSize="13"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <BoxView Grid.Column="1" Color="#10B981" HeightRequest="2" VerticalOptions="Center"/>
                    <Border Grid.Column="2" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#10B981">
                        <Label Text="&#x2713;" FontFamily="FASolid" FontSize="13"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <BoxView Grid.Column="3" Color="#10B981" HeightRequest="2" VerticalOptions="Center"/>
                    <Border Grid.Column="4" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#10B981">
                        <Label Text="&#x2713;" FontFamily="FASolid" FontSize="13"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <BoxView Grid.Column="5" Color="#10B981" HeightRequest="2" VerticalOptions="Center"/>
                    <Border Grid.Column="6" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#10B981">
                        <Label Text="&#x2713;" FontFamily="FASolid" FontSize="13"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <BoxView Grid.Column="7" Color="#6C63FF" HeightRequest="2" VerticalOptions="Center"/>
                    <Border Grid.Column="8" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#6C63FF">
                        <Label Text="5" FontFamily="Inter" FontAttributes="Bold" FontSize="13"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Step label -->
                <Label Text="Step 5 of 5 — Job Requirements"
                       FontFamily="Inter"
                       FontSize="12"
                       TextColor="#94A3B8"
                       HorizontalOptions="Center"
                       Margin="0,0,0,28"/>

                <!-- Card -->
                <Border StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="White" Padding="24,28">
                    <Border.Shadow>
                        <Shadow Brush="#64748B" Offset="0,4" Radius="16" Opacity="0.06"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="24">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Required Skills"
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="20"
                                   TextColor="#0F172A"/>
                            <Label Text="Select or add the skills you need from candidates"
                                   FontFamily="Inter"
                                   FontSize="13"
                                   TextColor="#64748B"/>
                        </VerticalStackLayout>

                        <!-- Predefined Skills Grid -->
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Popular Skills" 
                                   FontFamily="Inter"
                                   FontSize="12" 
                                   FontAttributes="Bold"
                                   TextColor="#64748B"/>
                            
                            <Grid ColumnSpacing="10" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Button Grid.Row="0" Grid.Column="0" 
                                        Text="Web Development" 
                                        Clicked="OnSkillTapped"
                                        BackgroundColor="White" 
                                        TextColor="#0F172A" 
                                        BorderColor="#E2E8F0"
                                        BorderWidth="2"
                                        FontFamily="Inter"
                                        FontSize="13"
                                        CornerRadius="12" 
                                        HeightRequest="44"/>
                                
                                <Button Grid.Row="0" Grid.Column="1" 
                                        Text="Mobile Dev" 
                                        Clicked="OnSkillTapped"
                                        BackgroundColor="White" 
                                        TextColor="#0F172A" 
                                        BorderColor="#E2E8F0"
                                        BorderWidth="2"
                                        FontFamily="Inter"
                                        FontSize="13"
                                        CornerRadius="12" 
                                        HeightRequest="44"/>
                                
                                <Button Grid.Row="1" Grid.Column="0" 
                                        Text="Graphic Design" 
                                        Clicked="OnSkillTapped"
                                        BackgroundColor="White" 
                                        TextColor="#0F172A" 
                                        BorderColor="#E2E8F0"
                                        BorderWidth="2"
                                        FontFamily="Inter"
                                        FontSize="13"
                                        CornerRadius="12" 
                                        HeightRequest="44"/>
                                
                                <Button Grid.Row="1" Grid.Column="1" 
                                        Text="Data Entry" 
                                        Clicked="OnSkillTapped"
                                        BackgroundColor="White" 
                                        TextColor="#0F172A" 
                                        BorderColor="#E2E8F0"
                                        BorderWidth="2"
                                        FontFamily="Inter"
                                        FontSize="13"
                                        CornerRadius="12" 
                                        HeightRequest="44"/>
                                
                                <Button Grid.Row="2" Grid.Column="0" 
                                        Text="Customer Service" 
                                        Clicked="OnSkillTapped"
                                        BackgroundColor="White" 
                                        TextColor="#0F172A" 
                                        BorderColor="#E2E8F0"
                                        BorderWidth="2"
                                        FontFamily="Inter"
                                        FontSize="13"
                                        CornerRadius="12" 
                                        HeightRequest="44"/>
                                
                                <Button Grid.Row="2" Grid.Column="1" 
                                        Text="Sales" 
                                        Clicked="OnSkillTapped"
                                        BackgroundColor="White" 
                                        TextColor="#0F172A" 
                                        BorderColor="#E2E8F0"
                                        BorderWidth="2"
                                        FontFamily="Inter"
                                        FontSize="13"
                                        CornerRadius="12" 
                                        HeightRequest="44"/>
                                
                                <Button Grid.Row="3" Grid.Column="0" 
                                        Text="Marketing" 
                                        Clicked="OnSkillTapped"
                                        BackgroundColor="White" 
                                        TextColor="#0F172A" 
                                        BorderColor="#E2E8F0"
                                        BorderWidth="2"
                                        FontFamily="Inter"
                                        FontSize="13"
                                        CornerRadius="12" 
                                        HeightRequest="44"/>
                                
                                <Button Grid.Row="3" Grid.Column="1" 
                                        Text="Accounting" 
                                        Clicked="OnSkillTapped"
                                        BackgroundColor="White" 
                                        TextColor="#0F172A" 
                                        BorderColor="#E2E8F0"
                                        BorderWidth="2"
                                        FontFamily="Inter"
                                        FontSize="13"
                                        CornerRadius="12" 
                                        HeightRequest="44"/>
                            </Grid>
                        </VerticalStackLayout>
                        
                        <!-- Custom Skill Input -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Add Custom Requirement" 
                                   FontFamily="Inter"
                                   FontSize="12" 
                                   FontAttributes="Bold"
                                   TextColor="#64748B"/>
                            
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0"
                                        Stroke="#E2E8F0" 
                                        StrokeThickness="2"
                                        BackgroundColor="White"
                                        Padding="16,0"
                                        StrokeShape="RoundRectangle 12">
                                    <Entry x:Name="SkillEntry" 
                                           Placeholder="Type a skill or requirement" 
                                           PlaceholderColor="#94A3B8"
                                           TextColor="#0F172A"
                                           FontFamily="Inter"
                                           FontSize="14"
                                           HeightRequest="48"
                                           BackgroundColor="Transparent"/>
                                </Border>
                                
                                <Button Grid.Column="1"
                                        Text="Add" 
                                        Clicked="OnAddSkill"
                                        BackgroundColor="#6C63FF" 
                                        TextColor="White" 
                                        FontFamily="Inter"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        CornerRadius="12" 
                                        HeightRequest="48"
                                        WidthRequest="80"/>
                            </Grid>
                        </VerticalStackLayout>
                        
                        <!-- Selected Skills Section -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Selected Requirements" 
                                   FontFamily="Inter"
                                   FontSize="12" 
                                   FontAttributes="Bold"
                                   TextColor="#64748B"/>
                            
                            <Border Stroke="#E2E8F0" 
                                    StrokeThickness="2"
                                    BackgroundColor="#F8FAFC"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="16"
                                    MinimumHeightRequest="100">
                                <VerticalStackLayout>
                                    <Label x:Name="NoSkillsLabel"
                                           Text="No requirements added yet" 
                                           FontFamily="Inter"
                                           FontSize="13" 
                                           TextColor="#94A3B8"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           Margin="0,16"/>
                                    <FlexLayout x:Name="SkillsWrap" 
                                               Wrap="Wrap" 
                                               AlignItems="Start" 
                                               AlignContent="Start" 
                                               Direction="Row"
                                               JustifyContent="Start"/>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
                
                <!-- Buttons -->
                <Grid ColumnSpacing="14" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" 
                            Text="Back" 
                            Clicked="OnBackTapped"
                            BackgroundColor="White" 
                            TextColor="#1C2B53" 
                            BorderColor="#E2E8F0"
                            BorderWidth="2"
                            FontFamily="Inter"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="12" 
                            HeightRequest="54"/>
                    
                    <Button Grid.Column="1" 
                            Text="Complete Registration" 
                            Clicked="OnFinish"
                            BackgroundColor="#6C63FF" 
                            TextColor="White" 
                            FontFamily="Inter"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="12" 
                            HeightRequest="54"/>
                </Grid>
                
                <!-- Login Link -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,16,0,0">
                    <Label Text="Already have an account?" 
                           FontFamily="Inter"
                           FontSize="14" 
                           TextColor="#64748B"/>
                    <Label Text="Sign in" 
                           FontFamily="Inter"
                           FontSize="14" 
                           TextColor="#6C63FF"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" 
              Grid.Row="0"
              BackgroundColor="#80000000" 
              IsVisible="False">
            <Border BackgroundColor="White" 
                    Stroke="#E2E8F0" 
                    StrokeShape="RoundRectangle 20" 
                    Padding="32,28" 
                    VerticalOptions="Center" 
                    HorizontalOptions="Center"
                    WidthRequest="280">
                <Border.Shadow>
                    <Shadow Brush="#0F172A" Offset="0,8" Radius="24" Opacity="0.15"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" 
                                     Color="#6C63FF" 
                                     WidthRequest="48" 
                                     HeightRequest="48"/>
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Completing Registration" 
                               FontFamily="Inter"
                               TextColor="#0F172A" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                        <Label Text="Please wait a moment..." 
                               FontFamily="Inter"
                               TextColor="#64748B" 
                               FontSize="13"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</base:BasePage>

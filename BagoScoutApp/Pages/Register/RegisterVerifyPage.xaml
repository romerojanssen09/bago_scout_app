<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             x:Class="BagoScoutApp.Pages.Register.RegisterVerifyPage"
             Title="Register: Verify"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,40,20,20" Spacing="32">
                <!-- Close Button -->
                <Label Text="&#x2715;" 
                       FontSize="24" 
                       TextColor="{StaticResource Gray500}"
                       HorizontalOptions="End"
                       VerticalOptions="Start">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseTapped"/>
                    </Label.GestureRecognizers>
                </Label>
                
                <!-- Title Section -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,-20,0,0">
                    <Label Text="Create Account" 
                           FontSize="32" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource PrimaryDark}"
                           HorizontalOptions="Center"/>
                    <Label Text="Join BagoScout today" 
                           FontSize="16" 
                           TextColor="{StaticResource Gray500}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
                <!-- Progress Steps -->
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <!-- Step 1 - Completed -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Primary}">
                            <Label Text="&#x2713;" 
                                   FontFamily="FASolid"
                                   FontSize="20" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView Color="{StaticResource Primary}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 2 - Completed -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Primary}">
                            <Label Text="&#x2713;" 
                                   FontFamily="FASolid"
                                   FontSize="20" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView Color="{StaticResource Primary}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 3 - Active -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Primary}">
                            <Label Text="3" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView Color="{StaticResource Gray200}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 4 -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Gray200}">
                            <Label Text="4" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView Color="{StaticResource Gray200}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 5 -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Gray200}">
                            <Label Text="5" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>
                    
                    <!-- Step Labels -->
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="Type" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label Text="Account" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label Text="Verify" 
                               FontSize="12" 
                               TextColor="{StaticResource Primary}"
                               FontAttributes="Bold"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label Text="ID" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label Text="Skills" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                
                <!-- Form Title -->
                <Label Text="Verify Your Email" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="{StaticResource PrimaryDark}"
                       HorizontalOptions="Center"/>
                
                <Label Text="Enter the 6-digit code sent to your email" 
                       FontSize="15" 
                       TextColor="{StaticResource Gray500}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
                
                <!-- Code Entry - Single Entry for simplicity -->
                <Border Stroke="{StaticResource Gray200}" 
                        StrokeThickness="1"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 12"
                        HorizontalOptions="Center"
                        WidthRequest="200"
                        Padding="12,0">
                    <Entry x:Name="CodeEntry" 
                           Placeholder="000000" 
                           Keyboard="Numeric" 
                           MaxLength="6"
                           PlaceholderColor="{StaticResource Gray400}"
                           TextColor="{StaticResource PrimaryDark}"
                           FontSize="24"
                           FontAttributes="Bold"
                           HeightRequest="56"
                           HorizontalTextAlignment="Center"
                           BackgroundColor="Transparent"/>
                </Border>
                
                <!-- Resend Link -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                    <Label Text="Didn't receive code?" 
                           FontSize="14" 
                           TextColor="{StaticResource Gray500}"/>
                    <Label Text="Resend" 
                           FontSize="14" 
                           TextColor="{StaticResource Primary}"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnResend"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                
                <!-- Buttons -->
                <Grid ColumnSpacing="12" Margin="0,32,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" 
                            Text="Back" 
                            Clicked="OnBackTapped"
                            BackgroundColor="White" 
                            TextColor="{StaticResource PrimaryDark}" 
                            BorderColor="{StaticResource Gray200}"
                            BorderWidth="1"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="12" 
                            HeightRequest="56"/>
                    
                    <Button Grid.Column="1" 
                            Text="Next" 
                            Clicked="OnVerify"
                            BackgroundColor="{StaticResource Primary}" 
                            TextColor="White" 
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="12" 
                            HeightRequest="56"/>
                </Grid>
                
                <!-- Login Link -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                    <Label Text="Already have an account?" 
                           FontSize="14" 
                           TextColor="{StaticResource Gray500}"/>
                    <Label Text="Log in" 
                           FontSize="14" 
                           TextColor="{StaticResource Primary}"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</base:BasePage>

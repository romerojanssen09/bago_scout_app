<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             x:Class="BagoScoutApp.Pages.Register.RegisterAccountPage"
             Title="Register"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8FAFC">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24,52,24,32" Spacing="0">

                <!-- Close -->
                <Label Text="&#xf00d;"
                       FontFamily="FASolid"
                       FontSize="18"
                       TextColor="#94A3B8"
                       HorizontalOptions="End"
                       Margin="0,0,0,24">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseTapped"/>
                    </Label.GestureRecognizers>
                </Label>

                <!-- Brand -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center" Margin="0,0,0,32">
                    <Label Text="BagoScout"
                           FontFamily="Inter"
                           FontAttributes="Bold"
                           FontSize="28"
                           TextColor="#1C2B53"
                           HorizontalOptions="Center"/>
                    <Label Text="Create your account"
                           FontFamily="Inter"
                           FontSize="15"
                           TextColor="#64748B"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Progress stepper -->
                <Grid Margin="0,0,0,8" HorizontalOptions="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#6C63FF">
                        <Label Text="&#xf00c;" FontFamily="FASolid" FontSize="13"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <BoxView Grid.Column="1" Color="#6C63FF" HeightRequest="2" VerticalOptions="Center"/>
                    <Border Grid.Column="2" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#6C63FF">
                        <Label Text="2" FontFamily="Inter" FontAttributes="Bold" FontSize="13"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <BoxView Grid.Column="3" Color="#E2E8F0" HeightRequest="2" VerticalOptions="Center"/>
                    <Border Grid.Column="4" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#E2E8F0">
                        <Label Text="3" FontFamily="Inter" FontAttributes="Bold" FontSize="13"
                               TextColor="#94A3B8" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <BoxView Grid.Column="5" Color="#E2E8F0" HeightRequest="2" VerticalOptions="Center"/>
                    <Border Grid.Column="6" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#E2E8F0">
                        <Label Text="4" FontFamily="Inter" FontAttributes="Bold" FontSize="13"
                               TextColor="#94A3B8" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <BoxView Grid.Column="7" Color="#E2E8F0" HeightRequest="2" VerticalOptions="Center"/>
                    <Border Grid.Column="8" WidthRequest="32" HeightRequest="32"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#E2E8F0">
                        <Label Text="5" FontFamily="Inter" FontAttributes="Bold" FontSize="13"
                               TextColor="#94A3B8" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <Label Text="Step 2 of 5 — Your Details"
                       FontFamily="Inter"
                       FontSize="12"
                       TextColor="#94A3B8"
                       HorizontalOptions="Center"
                       Margin="0,0,0,28"/>

                <!-- Form card -->
                <Border StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="White" Padding="24,28">
                    <Border.Shadow>
                        <Shadow Brush="#64748B" Offset="0,4" Radius="16" Opacity="0.06"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Account Details"
                                   FontFamily="Inter"
                                   FontAttributes="Bold"
                                   FontSize="20"
                                   TextColor="#0F172A"/>
                            <Label Text="Fill in your personal information"
                                   FontFamily="Inter"
                                   FontSize="13"
                                   TextColor="#64748B"/>
                        </VerticalStackLayout>

                        <!-- Name row -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="First Name" FontFamily="Inter" FontSize="12"
                                       FontAttributes="Bold" TextColor="#475569"/>
                                <Border Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White"
                                        Padding="12,0" StrokeShape="RoundRectangle 10">
                                    <Entry x:Name="FirstNameEntry"
                                           Placeholder="First"
                                           PlaceholderColor="#CBD5E1"
                                           TextColor="#0F172A"
                                           FontFamily="Inter"
                                           FontSize="14"
                                           HeightRequest="46"
                                           BackgroundColor="Transparent"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="Last Name" FontFamily="Inter" FontSize="12"
                                       FontAttributes="Bold" TextColor="#475569"/>
                                <Border Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White"
                                        Padding="12,0" StrokeShape="RoundRectangle 10">
                                    <Entry x:Name="LastNameEntry"
                                           Placeholder="Last"
                                           PlaceholderColor="#CBD5E1"
                                           TextColor="#0F172A"
                                           FontFamily="Inter"
                                           FontSize="14"
                                           HeightRequest="46"
                                           BackgroundColor="Transparent"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email Address" FontFamily="Inter" FontSize="12"
                                   FontAttributes="Bold" TextColor="#475569"/>
                            <Border Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White"
                                    StrokeShape="RoundRectangle 10">
                                <Grid Padding="12,0" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Text="&#xf0e0;" FontFamily="FASolid"
                                           FontSize="14" TextColor="#94A3B8" VerticalOptions="Center"/>
                                    <Entry Grid.Column="1" x:Name="EmailEntry"
                                           Placeholder="you@example.com"
                                           Keyboard="Email"
                                           PlaceholderColor="#CBD5E1"
                                           TextColor="#0F172A"
                                           FontFamily="Inter"
                                           FontSize="14"
                                           HeightRequest="46"
                                           BackgroundColor="Transparent"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password" FontFamily="Inter" FontSize="12"
                                   FontAttributes="Bold" TextColor="#475569"/>
                            <Border Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White"
                                    StrokeShape="RoundRectangle 10">
                                <Grid Padding="12,0" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Text="&#xf023;" FontFamily="FASolid"
                                           FontSize="14" TextColor="#94A3B8" VerticalOptions="Center"/>
                                    <Entry Grid.Column="1" x:Name="PasswordEntry"
                                           IsPassword="True"
                                           Placeholder="Create a strong password"
                                           PlaceholderColor="#CBD5E1"
                                           TextColor="#0F172A"
                                           FontFamily="Inter"
                                           FontSize="14"
                                           HeightRequest="46"
                                           BackgroundColor="Transparent"/>
                                    <Label Grid.Column="2" x:Name="TogglePwdIcon"
                                           FontFamily="FARegular" Text="&#xf06e;"
                                           FontSize="16" VerticalOptions="Center" TextColor="#94A3B8">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTogglePassword"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>

                            <!-- Password requirements -->
                            <Grid ColumnSpacing="16" RowSpacing="6" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                    <Label x:Name="LengthDot" Text="●" FontSize="8" TextColor="#E2E8F0" VerticalOptions="Center"/>
                                    <Label Text="8+ characters" FontFamily="Inter" FontSize="11" TextColor="#64748B"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                                    <Label x:Name="UppercaseDot" Text="●" FontSize="8" TextColor="#E2E8F0" VerticalOptions="Center"/>
                                    <Label Text="Uppercase letter" FontFamily="Inter" FontSize="11" TextColor="#64748B"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                                    <Label x:Name="NumberDot" Text="●" FontSize="8" TextColor="#E2E8F0" VerticalOptions="Center"/>
                                    <Label Text="One number" FontFamily="Inter" FontSize="11" TextColor="#64748B"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                                    <Label x:Name="SpecialDot" Text="●" FontSize="8" TextColor="#E2E8F0" VerticalOptions="Center"/>
                                    <Label Text="Special character" FontFamily="Inter" FontSize="11" TextColor="#64748B"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Confirm Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Confirm Password" FontFamily="Inter" FontSize="12"
                                   FontAttributes="Bold" TextColor="#475569"/>
                            <Border Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White"
                                    StrokeShape="RoundRectangle 10">
                                <Grid Padding="12,0" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Text="&#xf023;" FontFamily="FASolid"
                                           FontSize="14" TextColor="#94A3B8" VerticalOptions="Center"/>
                                    <Entry Grid.Column="1" x:Name="ConfirmPasswordEntry"
                                           IsPassword="True"
                                           Placeholder="Re-enter password"
                                           PlaceholderColor="#CBD5E1"
                                           TextColor="#0F172A"
                                           FontFamily="Inter"
                                           FontSize="14"
                                           HeightRequest="46"
                                           BackgroundColor="Transparent"/>
                                    <Label Grid.Column="2" x:Name="ToggleConfirmPwdIcon"
                                           FontFamily="FARegular" Text="&#xf06e;"
                                           FontSize="16" VerticalOptions="Center" TextColor="#94A3B8">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnToggleConfirmPassword"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Buttons -->
                <Grid ColumnSpacing="12" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="1"
                            Stroke="#E2E8F0" BackgroundColor="White" HeightRequest="54">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="Back" FontFamily="Inter" FontAttributes="Bold"
                               FontSize="15" TextColor="#475569"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Button Grid.Column="1" Text="Continue"
                            Clicked="OnSendCode"
                            BackgroundColor="#1C2B53"
                            TextColor="White"
                            FontFamily="Inter"
                            FontAttributes="Bold"
                            FontSize="16"
                            CornerRadius="12"
                            HeightRequest="54"/>
                </Grid>

                <!-- Login link -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,16,0,0">
                    <Label Text="Already have an account?" FontFamily="Inter" FontSize="14" TextColor="#64748B"/>
                    <Label Text="Sign in" FontFamily="Inter" FontAttributes="Bold"
                           FontSize="14" TextColor="#6C63FF">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading overlay -->
        <Grid x:Name="LoadingOverlay" BackgroundColor="#80000000" IsVisible="False">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" StrokeThickness="0"
                    Padding="32" WidthRequest="200" VerticalOptions="Center" HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="#64748B" Offset="0,8" Radius="24" Opacity="0.12"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="#6C63FF" WidthRequest="40" HeightRequest="40"/>
                    <Label Text="Checking email…" FontFamily="Inter" FontAttributes="Bold"
                           FontSize="15" TextColor="#0F172A" HorizontalOptions="Center"/>
                    <Label Text="Please wait" FontFamily="Inter" FontSize="13"
                           TextColor="#64748B" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</base:BasePage>

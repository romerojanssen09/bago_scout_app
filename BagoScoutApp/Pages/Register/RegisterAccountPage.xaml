<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             x:Class="BagoScoutApp.Pages.Register.RegisterAccountPage"
             Title="Register: Account"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,40,20,20" Spacing="32">
                <!-- Close Button -->
                <Label Text="&#x2715;" 
                       FontSize="24" 
                       TextColor="{StaticResource Gray500}"
                       HorizontalOptions="End"
                       VerticalOptions="Start">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseTapped"/>
                    </Label.GestureRecognizers>
                </Label>
                
                <!-- Title Section -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,-20,0,0">
                    <Label Text="Create Account" 
                           FontSize="32" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource PrimaryDark}"
                           HorizontalOptions="Center"/>
                    <Label Text="Join BagoScout today" 
                           FontSize="16" 
                           TextColor="{StaticResource Gray500}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
                <!-- Progress Steps -->
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <!-- Step 1 - Completed -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Primary}">
                            <Label Text="&#x2713;" 
                                   FontFamily="FASolid"
                                   FontSize="20" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView Color="{StaticResource Primary}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 2 - Active -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Primary}">
                            <Label Text="2" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView Color="{StaticResource Gray200}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 3 -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Gray200}">
                            <Label Text="3" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView Color="{StaticResource Gray200}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 4 -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Gray200}">
                            <Label Text="4" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView Color="{StaticResource Gray200}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 5 -->
                        <Border WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Gray200}">
                            <Label Text="5" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>
                    
                    <!-- Step Labels -->
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="Type" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label Text="Account" 
                               FontSize="12" 
                               TextColor="{StaticResource Primary}"
                               FontAttributes="Bold"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label Text="Verify" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label Text="ID" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label Text="Skills" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                
                <!-- Form Title -->
                <Label Text="Create Your Account" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="{StaticResource PrimaryDark}"
                       HorizontalOptions="Center"/>
                
                <!-- Form Fields -->
                <VerticalStackLayout Spacing="20">
                    <!-- First Name -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="First Name" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"/>
                        <Border Stroke="{StaticResource Gray200}" 
                                StrokeThickness="1"
                                BackgroundColor="White"
                                Padding="12,0"
                                StrokeShape="RoundRectangle 12">
                            <Entry x:Name="FirstNameEntry" 
                                   Placeholder="Enter first name" 
                                   PlaceholderColor="{StaticResource Gray400}"
                                   TextColor="{StaticResource PrimaryDark}"
                                   HeightRequest="48"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>
                    
                    <!-- Last Name -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Last Name" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"/>
                        <Border Stroke="{StaticResource Gray200}" 
                                StrokeThickness="1"
                                BackgroundColor="White"
                                Padding="12,0"
                                StrokeShape="RoundRectangle 12">
                            <Entry x:Name="LastNameEntry" 
                                   Placeholder="Enter last name" 
                                   PlaceholderColor="{StaticResource Gray400}"
                                   TextColor="{StaticResource PrimaryDark}"
                                   HeightRequest="48"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>
                    
                    <!-- Email -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Email Address" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"/>
                        <Border Stroke="{StaticResource Gray200}" 
                                StrokeThickness="1"
                                BackgroundColor="White"
                                Padding="12,0"
                                StrokeShape="RoundRectangle 12">
                            <Entry x:Name="EmailEntry" 
                                   Placeholder="Enter your email" 
                                   Keyboard="Email"
                                   PlaceholderColor="{StaticResource Gray400}"
                                   TextColor="{StaticResource PrimaryDark}"
                                   HeightRequest="48"
                                   BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>
                    
                    <!-- Password -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Password" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"/>
                        <Border Stroke="{StaticResource Gray200}" 
                                StrokeThickness="1"
                                BackgroundColor="White"
                                StrokeShape="RoundRectangle 12">
                            <Grid Padding="12,0" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Entry Grid.Column="0" 
                                       x:Name="PasswordEntry" 
                                       IsPassword="True" 
                                       Placeholder="Create password"
                                       PlaceholderColor="{StaticResource Gray400}"
                                       TextColor="{StaticResource PrimaryDark}"
                                       HeightRequest="48"
                                       BackgroundColor="Transparent"/>
                                <Label Grid.Column="1" 
                                       x:Name="TogglePwdIcon"
                                       FontFamily="FARegular"
                                       Text="&#xf06e;"
                                       FontSize="18"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource Gray500}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTogglePassword"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                        
                        <!-- Password Requirements -->
                        <Grid ColumnSpacing="20" RowSpacing="4" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                <Label x:Name="LengthDot" Text="●" FontSize="8" TextColor="{StaticResource Gray200}" VerticalOptions="Center"/>
                                <Label Text="At least 8 characters" FontSize="12" TextColor="{StaticResource Gray500}"/>
                            </HorizontalStackLayout>
                            
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                                <Label x:Name="UppercaseDot" Text="●" FontSize="8" TextColor="{StaticResource Gray200}" VerticalOptions="Center"/>
                                <Label Text="One uppercase letter" FontSize="12" TextColor="{StaticResource Gray500}"/>
                            </HorizontalStackLayout>
                            
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                                <Label x:Name="NumberDot" Text="●" FontSize="8" TextColor="{StaticResource Gray200}" VerticalOptions="Center"/>
                                <Label Text="One number" FontSize="12" TextColor="{StaticResource Gray500}"/>
                            </HorizontalStackLayout>
                            
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                                <Label x:Name="SpecialDot" Text="●" FontSize="8" TextColor="{StaticResource Gray200}" VerticalOptions="Center"/>
                                <Label Text="One special character" FontSize="12" TextColor="{StaticResource Gray500}"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                    
                    <!-- Confirm Password -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Confirm Password" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"/>
                        <Border Stroke="{StaticResource Gray200}" 
                                StrokeThickness="1"
                                BackgroundColor="White"
                                StrokeShape="RoundRectangle 12">
                            <Grid Padding="12,0" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Entry Grid.Column="0" 
                                       x:Name="ConfirmPasswordEntry" 
                                       IsPassword="True" 
                                       Placeholder="Confirm password"
                                       PlaceholderColor="{StaticResource Gray400}"
                                       TextColor="{StaticResource PrimaryDark}"
                                       HeightRequest="48"
                                       BackgroundColor="Transparent"/>
                                <Label Grid.Column="1" 
                                       x:Name="ToggleConfirmPwdIcon"
                                       FontFamily="FARegular"
                                       Text="&#xf06e;"
                                       FontSize="18"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource Gray500}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnToggleConfirmPassword"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
                
                <!-- Buttons -->
                <Grid ColumnSpacing="12" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" 
                            Text="Back" 
                            Clicked="OnBackTapped"
                            BackgroundColor="White" 
                            TextColor="{StaticResource PrimaryDark}" 
                            BorderColor="{StaticResource Gray200}"
                            BorderWidth="1"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="12" 
                            HeightRequest="56"/>
                    
                    <Button Grid.Column="1" 
                            Text="Next" 
                            Clicked="OnSendCode"
                            BackgroundColor="{StaticResource Primary}" 
                            TextColor="White" 
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="12" 
                            HeightRequest="56"/>
                </Grid>
                
                <!-- Login Link -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                    <Label Text="Already have an account?" 
                           FontSize="14" 
                           TextColor="{StaticResource Gray500}"/>
                    <Label Text="Log in" 
                           FontSize="14" 
                           TextColor="{StaticResource Primary}"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" BackgroundColor="#80000000" IsVisible="False">
            <Border BackgroundColor="White" 
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 12"
                    Padding="32"
                    WidthRequest="220"
                    HeightRequest="220"
                    VerticalOptions="Center" 
                    HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16" VerticalOptions="Center">
                    <ActivityIndicator IsRunning="True" 
                                       Color="{StaticResource Primary}"
                                       WidthRequest="48"
                                       HeightRequest="48"/>
                    <Label Text="Checking email..." 
                           TextColor="{StaticResource PrimaryDark}"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Please wait" 
                           TextColor="{StaticResource Gray500}"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</base:BasePage>

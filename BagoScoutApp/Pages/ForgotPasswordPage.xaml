<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:base="clr-namespace:BagoScoutApp.Pages.Components"
             x:Class="BagoScoutApp.Pages.ForgotPasswordPage"
             Title="Forgot Password"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">
    
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,40,20,20" Spacing="32">
                <!-- Close Button -->
                <Label Text="&#x2715;" 
                       FontSize="24" 
                       TextColor="{StaticResource Gray500}"
                       HorizontalOptions="End"
                       VerticalOptions="Start">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseTapped"/>
                    </Label.GestureRecognizers>
                </Label>
                
                <!-- Title Section -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,-20,0,0">
                    <Label Text="Forgot Password" 
                           FontSize="32" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource PrimaryDark}"
                           HorizontalOptions="Center"/>
                    <Label Text="Recover your BagoScout account" 
                           FontSize="16" 
                           TextColor="{StaticResource Gray500}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                
                <!-- Progress Steps -->
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <!-- Step 1 Indicator -->
                        <Border x:Name="Step1Indicator" 
                                WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Primary}">
                            <Label x:Name="Step1IndicatorLabel" 
                                   Text="1" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView x:Name="Step1Line" 
                                 Color="{StaticResource Gray200}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 2 Indicator -->
                        <Border x:Name="Step2Indicator" 
                                WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Gray200}">
                            <Label x:Name="Step2IndicatorLabel" 
                                   Text="2" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        
                        <BoxView x:Name="Step2Line" 
                                 Color="{StaticResource Gray200}" 
                                 HeightRequest="2" 
                                 WidthRequest="40"
                                 VerticalOptions="Center"/>
                        
                        <!-- Step 3 Indicator -->
                        <Border x:Name="Step3Indicator" 
                                WidthRequest="48" 
                                HeightRequest="48" 
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource Gray200}">
                            <Label x:Name="Step3IndicatorLabel" 
                                   Text="3" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>
                    
                    <!-- Step Labels -->
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label x:Name="Step1Label" 
                               Text="Email" 
                               FontSize="12" 
                               TextColor="{StaticResource Primary}"
                               FontAttributes="Bold"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label x:Name="Step2Label" 
                               Text="Verify" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                        <BoxView WidthRequest="40" Opacity="0"/>
                        <Label x:Name="Step3Label" 
                               Text="Reset" 
                               FontSize="12" 
                               TextColor="{StaticResource Gray500}"
                               WidthRequest="48"
                               HorizontalTextAlignment="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                
                <!-- Step Views Container -->
                <Grid>
                    <!-- STEP 1: EMAIL ENTRY -->
                    <VerticalStackLayout x:Name="Step1View" Spacing="24" IsVisible="True">
                        <Label Text="Enter Email Address" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="{StaticResource PrimaryDark}"
                               HorizontalOptions="Center"/>
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email Address" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryDark}"/>
                            <Border Stroke="{StaticResource Gray200}" 
                                    StrokeThickness="1"
                                    BackgroundColor="White"
                                    Padding="12,0"
                                    StrokeShape="RoundRectangle 12">
                                <Entry x:Name="EmailEntry" 
                                       Placeholder="Enter your email" 
                                       Keyboard="Email"
                                       PlaceholderColor="{StaticResource Gray400}"
                                       TextColor="{StaticResource PrimaryDark}"
                                       HeightRequest="48"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>
                        
                        <!-- Info notice card matching the WebApp for consistent premium feel -->
                        <Border BackgroundColor="{StaticResource Secondary}" 
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 12"
                                Padding="16"
                                Margin="0,8,0,0">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="&#xf05a;" 
                                       FontFamily="FASolid"
                                       FontSize="18" 
                                       TextColor="{StaticResource Primary}"
                                       VerticalOptions="Center"/>
                                <Label Text="Notice: We will send a 6-digit OTP code to this email address if it is registered in our system." 
                                       TextColor="{StaticResource Primary}"
                                       FontSize="13"
                                       WidthRequest="280"
                                       LineBreakMode="WordWrap"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                    
                    <!-- STEP 2: OTP VERIFICATION -->
                    <VerticalStackLayout x:Name="Step2View" Spacing="24" IsVisible="False">
                        <Label Text="Verify Your OTP" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="{StaticResource PrimaryDark}"
                               HorizontalOptions="Center"/>
                        
                        <Label Text="Enter the 6-digit code sent to your email" 
                               FontSize="15" 
                               TextColor="{StaticResource Gray500}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        
                        <Border Stroke="{StaticResource Gray200}" 
                                StrokeThickness="1"
                                BackgroundColor="White"
                                StrokeShape="RoundRectangle 12"
                                HorizontalOptions="Center"
                                WidthRequest="200"
                                Margin="0,12"
                                Padding="12,0">
                            <Entry x:Name="CodeEntry" 
                                   Placeholder="000000" 
                                   Keyboard="Numeric" 
                                   MaxLength="6"
                                   PlaceholderColor="{StaticResource Gray400}"
                                   TextColor="{StaticResource PrimaryDark}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   HeightRequest="56"
                                   HorizontalTextAlignment="Center"
                                   BackgroundColor="Transparent"/>
                        </Border>
                        
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Didn't receive code?" 
                                   FontSize="14" 
                                   TextColor="{StaticResource Gray500}"/>
                            <Label Text="Resend" 
                                   FontSize="14" 
                                   TextColor="{StaticResource Primary}"
                                   FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnResendTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    
                    <!-- STEP 3: RESET PASSWORD -->
                    <VerticalStackLayout x:Name="Step3View" Spacing="24" IsVisible="False">
                        <Label Text="Reset Your Password" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="{StaticResource PrimaryDark}"
                               HorizontalOptions="Center"/>
                        
                        <VerticalStackLayout Spacing="20">
                            <!-- New Password -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="New Password" 
                                       FontSize="14" 
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource PrimaryDark}"/>
                                <Border Stroke="{StaticResource Gray200}" 
                                        StrokeThickness="1"
                                        BackgroundColor="White"
                                        Padding="12,0"
                                        StrokeShape="RoundRectangle 12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Entry Grid.Column="0" 
                                               x:Name="PasswordEntry" 
                                               IsPassword="True" 
                                               Placeholder="Create password"
                                               PlaceholderColor="{StaticResource Gray400}"
                                               TextColor="{StaticResource PrimaryDark}"
                                               HeightRequest="48"
                                               BackgroundColor="Transparent"/>
                                        <Label Grid.Column="1" 
                                               x:Name="TogglePwdIcon"
                                               FontFamily="FARegular"
                                               Text="&#xf06e;"
                                               FontSize="18"
                                               VerticalOptions="Center"
                                               TextColor="{StaticResource Gray500}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnTogglePasswordTapped"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                </Border>
                                
                                <!-- Password Requirements dots -->
                                <Grid ColumnSpacing="20" RowSpacing="4" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                        <Label x:Name="LengthDot" Text="●" FontSize="8" TextColor="{StaticResource Gray200}" VerticalOptions="Center"/>
                                        <Label Text="At least 8 characters" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                    </HorizontalStackLayout>
                                    
                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                                        <Label x:Name="UppercaseDot" Text="●" FontSize="8" TextColor="{StaticResource Gray200}" VerticalOptions="Center"/>
                                        <Label Text="One uppercase letter" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                    </HorizontalStackLayout>
                                    
                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                                        <Label x:Name="NumberDot" Text="●" FontSize="8" TextColor="{StaticResource Gray200}" VerticalOptions="Center"/>
                                        <Label Text="One number" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                    </HorizontalStackLayout>
                                    
                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                                        <Label x:Name="SpecialDot" Text="●" FontSize="8" TextColor="{StaticResource Gray200}" VerticalOptions="Center"/>
                                        <Label Text="One special character" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                            
                            <!-- Confirm Password -->
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Confirm Password" 
                                       FontSize="14" 
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource PrimaryDark}"/>
                                <Border Stroke="{StaticResource Gray200}" 
                                        StrokeThickness="1"
                                        BackgroundColor="White"
                                        Padding="12,0"
                                        StrokeShape="RoundRectangle 12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Entry Grid.Column="0" 
                                               x:Name="ConfirmPasswordEntry" 
                                               IsPassword="True" 
                                               Placeholder="Confirm password"
                                               PlaceholderColor="{StaticResource Gray400}"
                                               TextColor="{StaticResource PrimaryDark}"
                                               HeightRequest="48"
                                               BackgroundColor="Transparent"/>
                                        <Label Grid.Column="1" 
                                               x:Name="ToggleConfirmPwdIcon"
                                               FontFamily="FARegular"
                                               Text="&#xf06e;"
                                               FontSize="18"
                                               VerticalOptions="Center"
                                               TextColor="{StaticResource Gray500}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnToggleConfirmPasswordTapped"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                </Border>
                                <Label x:Name="MatchLabel" Text="" FontSize="12" TextColor="#EF4444" Margin="0,4,0,0" IsVisible="False"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Grid>
                
                <!-- Action Buttons -->
                <Grid ColumnSpacing="12" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="BackBtn"
                            Grid.Column="0" 
                            Text="Back" 
                            Clicked="OnBackTapped"
                            BackgroundColor="White" 
                            TextColor="{StaticResource PrimaryDark}" 
                            BorderColor="{StaticResource Gray200}"
                            BorderWidth="1"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="12" 
                            HeightRequest="56"
                            IsVisible="False"/>
                    
                    <Button x:Name="NextBtn"
                            Grid.Column="1" 
                            Text="Next" 
                            Clicked="OnNextTapped"
                            BackgroundColor="{StaticResource Primary}" 
                            TextColor="White" 
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="12" 
                            HeightRequest="56"/>
                </Grid>
                
                <!-- Bottom Login Link -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,16,0,0">
                    <Label Text="Remembered your password?" 
                           FontSize="14" 
                           TextColor="{StaticResource Gray500}"/>
                    <Label Text="Log in" 
                           FontSize="14" 
                           TextColor="{StaticResource Primary}"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" BackgroundColor="#80000000" IsVisible="False">
            <Border BackgroundColor="White" 
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 12"
                    Padding="32"
                    WidthRequest="220"
                    HeightRequest="220"
                    VerticalOptions="Center" 
                    HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16" VerticalOptions="Center">
                    <ActivityIndicator IsRunning="True" 
                                       Color="{StaticResource Primary}"
                                       WidthRequest="48"
                                       HeightRequest="48"/>
                      <Label x:Name="LoadingText" 
                             Text="Sending OTP..." 
                             TextColor="{StaticResource PrimaryDark}"
                             FontSize="16"
                             FontAttributes="Bold"
                             HorizontalOptions="Center"/>
                    <Label Text="Please wait" 
                           TextColor="{StaticResource Gray500}"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</base:BasePage>
